@page
@model SBS.WebApp.Pages.Manager.Pools.IndexModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Quản lý Bể bơi";
    ViewData["Breadcrumb"] = "Quản lý / Bể bơi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold text-dark mb-1">Quản lý Bể bơi</h4>
        <p class="text-muted small mb-0">Theo dõi, cập nhật thông tin và trạng thái các bể bơi trong hệ thống.</p>
    </div>
    <a href="/Manager/Pools/Create" class="btn btn-primary shadow-sm rounded-pill px-4 fw-medium">
        <i class="fa-solid fa-plus me-2"></i>Thêm bể bơi mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
    <div class="card-header bg-white border-bottom p-4">
        <div class="row g-3 align-items-center">
            <div class="col-md-6 col-lg-4">
                <div class="input-group shadow-sm rounded-pill overflow-hidden border">
                    <span class="input-group-text bg-white border-0 text-primary ps-4"><i class="fa-solid fa-search"></i></span>
                    <input type="text" id="searchInput" class="form-control border-0 bg-white" placeholder="Tìm tên bể bơi, địa chỉ...">
                </div>
            </div>
            <div class="col-md-6 col-lg-3">
                <select id="statusFilter" class="form-select shadow-sm rounded-pill border">
                    <option value="">Tất cả trạng thái</option>
                    <option value="Active">Hoạt động (Active)</option>
                    <option value="Closed">Tạm đóng (Closed)</option>
                </select>
            </div>
        </div>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="bg-light">
                <tr>
                    <th class="ps-4 text-secondary small fw-bold text-uppercase py-3">Bể bơi</th>
                    <th class="text-secondary small fw-bold text-uppercase py-3">Địa chỉ</th>
                    <th class="text-secondary small fw-bold text-uppercase text-center py-3">Giờ hoạt động</th>
                    <th class="text-secondary small fw-bold text-uppercase text-center py-3">Trạng thái</th>
                    <th class="pe-4 text-secondary small fw-bold text-uppercase text-end py-3">Hành động</th>
                </tr>
            </thead>
            <tbody id="poolTableBody">
                <tr><td colspan="5" class="text-center p-5 text-muted"><div class="spinner-border text-primary me-2" role="status"></div>Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
    <div class="card-footer bg-white border-top p-3 d-flex justify-content-between align-items-center">
        <div class="text-muted small" id="pageInfo">Hiển thị 0-0 trong 0 bể bơi</div>
        <ul class="pagination pagination-sm mb-0 gap-1" id="pagination"></ul>
    </div>
</div>

<!-- Confirm Close Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fa-solid fa-triangle-exclamation text-warning mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3" id="confirmTitle">Xác nhận đóng</h5>
                <p class="text-muted mb-4" id="confirmMessage">Bạn có chắc chắn muốn thực hiện?</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light border w-50" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger w-50" id="btnConfirmAction">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        let confirmActionCb = null;
        let currentPage = 1;
        const pageSize = 5;

        $(document).ready(function() {
            loadPools(1);

            let searchTimeout = null;
            $('#searchInput').on('input', function() {
                clearTimeout(searchTimeout);
                searchTimeout = setTimeout(() => loadPools(1), 500);
            });
            $('#statusFilter').on('change', function() { loadPools(1); });
        });

        async function loadPools(page) {
            currentPage = page;
            const search = $('#searchInput').val();
            const status = $('#statusFilter').val();
            let url = `/pools?page=${page}&pageSize=${pageSize}`;
            if (search) url += `&search=${encodeURIComponent(search)}`;
            if (status) url += `&status=${status}`;

            try {
                const res = await api.get(url);
                renderTable(res.items || []);
                renderPagination(res.totalCount, res.page, res.pageSize);
            } catch (error) {
                $('#poolTableBody').html('<tr><td colspan="5" class="text-center p-4 text-danger">Lỗi tải dữ liệu.</td></tr>');
            }
        }

        function renderPagination(totalCount, page, pSize) {
            const totalPages = Math.ceil(totalCount / pSize) || 1;
            const startItem = (page - 1) * pSize + 1;
            const endItem = Math.min(page * pSize, totalCount);
            
            $('#pageInfo').html(`<span class="fw-semibold text-dark">${totalCount === 0 ? 0 : startItem} - ${endItem}</span> trong <span class="fw-semibold text-dark">${totalCount}</span> bể bơi`);

            let html = '';
            html += `<li class="page-item ${page === 1 ? 'disabled' : ''}"><a class="page-link px-3" href="#" onclick="loadPools(${page - 1}); return false;"><i class="fa-solid fa-chevron-left"></i></a></li>`;
            
            // Professional sliding pagination
            let startPage = Math.max(1, page - 2);
            let endPage = Math.min(totalPages, page + 2);
            
            if (startPage > 1) {
                html += `<li class="page-item"><a class="page-link" href="#" onclick="loadPools(1); return false;">1</a></li>`;
                if (startPage > 2) {
                    html += `<li class="page-item disabled"><span class="page-link border-0">...</span></li>`;
                }
            }
            
            for(let i = startPage; i <= endPage; i++) {
                html += `<li class="page-item ${page === i ? 'active' : ''}"><a class="page-link px-3" href="#" onclick="loadPools(${i}); return false;">${i}</a></li>`;
            }
            
            if (endPage < totalPages) {
                if (endPage < totalPages - 1) {
                    html += `<li class="page-item disabled"><span class="page-link border-0">...</span></li>`;
                }
                html += `<li class="page-item"><a class="page-link px-3" href="#" onclick="loadPools(${totalPages}); return false;">${totalPages}</a></li>`;
            }
            
            html += `<li class="page-item ${page === totalPages ? 'disabled' : ''}"><a class="page-link px-3" href="#" onclick="loadPools(${page + 1}); return false;"><i class="fa-solid fa-chevron-right"></i></a></li>`;
            
            $('#pagination').html(html);
        }

        function renderTable(list) {
            let html = '';
            if (list.length === 0) {
                html = '<tr><td colspan="5" class="text-center text-muted p-5"><i class="fa-solid fa-inbox fa-4x mb-3 text-light"></i><br><span class="fs-5 fw-medium">Không tìm thấy bể bơi nào.</span></td></tr>';
            } else {
                list.forEach(p => {
                    const isClosed = p.status !== 'Active';
                    const badgeClass = isClosed ? 'bg-danger text-danger' : 'bg-success text-success';
                    const badgeText = isClosed ? 'TẠM ĐÓNG' : 'HOẠT ĐỘNG';
                    
                    const coverImg = p.images && p.images.length > 0 ? p.images.find(i => i.isCover)?.imageUrl || p.images[0].imageUrl : 'https://placehold.co/100x100?text=No+Image';

                    const toggleBtn = isClosed 
                        ? `<button class="btn btn-sm btn-outline-success border-0 me-1 shadow-sm" onclick="reopenPool(${p.poolId})" title="Mở lại"><i class="fa-solid fa-lock-open"></i></button>`
                        : `<button class="btn btn-sm btn-outline-warning border-0 me-1 shadow-sm" onclick="confirmClose(${p.poolId}, '${p.poolName}')" title="Đóng tạm thời"><i class="fa-solid fa-lock"></i></button>`;

                    html += `
                        <tr class="align-middle">
                            <td class="ps-4 py-3">
                                <div class="d-flex align-items-center gap-3">
                                    <div class="position-relative">
                                        <img src="${coverImg}" alt="${p.poolName}" class="rounded-3 object-fit-cover shadow-sm border" width="65" height="65">
                                        ${isClosed ? '<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark bg-opacity-50 rounded-3 d-flex align-items-center justify-content-center"><i class="fa-solid fa-lock text-white"></i></div>' : ''}
                                    </div>
                                    <div>
                                        <div class="fw-bold text-dark fs-6 mb-1">${p.poolName}</div>
                                        <div class="text-muted small"><i class="fa-solid fa-ruler-combined text-primary me-1"></i>${p.area ? p.area + ' m²' : 'Chưa có'}</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="text-muted small d-flex align-items-start gap-2" style="max-width: 250px;">
                                    <i class="fa-solid fa-location-dot mt-1 text-danger"></i>
                                    <span style="white-space: normal; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">${p.address}</span>
                                </div>
                            </td>
                            <td class="text-center">
                                <div class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fw-semibold border border-primary-subtle">
                                    <i class="fa-regular fa-clock me-1"></i> ${p.openingTime.substring(0,5)} - ${p.closingTime.substring(0,5)}
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge ${badgeClass} bg-opacity-10 rounded-pill px-3 py-2 fw-bold border border-${isClosed ? 'danger' : 'success'}-subtle">${badgeText}</span>
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    ${toggleBtn}
                                    <a href="/Manager/Pools/Edit/${p.poolId}" class="btn btn-sm btn-outline-primary border-0 shadow-sm" title="Chỉnh sửa">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    `;
                });
            }
            $('#poolTableBody').html(html);
        }

        function confirmClose(id, name) {
            $('#confirmTitle').text('Đóng Bể Bơi?');
            $('#confirmMessage').text(`Bể bơi "${name}" sẽ không nhận Booking mới nữa.`);
            confirmActionCb = async () => {
                try {
                    await api.patch(`/pools/${id}/close`);
                    toastr.success('Đã đóng bể bơi.');
                    confirmModal.hide();
                    loadPools();
                } catch(e) {}
            };
            confirmModal.show();
        }

        async function reopenPool(id) {
            try {
                await api.patch(`/pools/${id}/reopen`);
                toastr.success('Đã mở lại bể bơi.');
                loadPools();
            } catch(e) {}
        }

        $('#btnConfirmAction').click(function() {
            if (confirmActionCb) confirmActionCb();
        });
    </script>
}
