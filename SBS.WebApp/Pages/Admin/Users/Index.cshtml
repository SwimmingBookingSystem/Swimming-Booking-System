@page
@model SBS.WebApp.Pages.Admin.Users.IndexModel
@{
    ViewData["Title"] = "Quản lý người dùng";
}

<h1>Quản lý người dùng</h1>

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="alert alert-info alert-dismissible fade show" role="alert">
        @Model.StatusMessage
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Tên đăng nhập</th>
            <th>Họ tên</th>
            <th>Email</th>
            <th>Số điện thoại</th>
            <th>Vai trò</th>
            <th>Trạng thái</th>
            <th>Ngày tạo</th>
            <th>Thao tác</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.UserName</td>
                <td>@user.FullName</td>
                <td>@user.Email</td>
                <td>@user.PhoneNumber</td>
                <td>@user.Role</td>
                <td>
                    @if (user.Status == "Active")
                    {
                        <span class="badge bg-success">Hoạt động</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Đã khóa</span>
                    }
                </td>
                <td>@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                <td>
                    @if (user.Status == "Active")
                    {
                        <form method="post" asp-page-handler="Lock" onsubmit="return confirm('Xác nhận khóa tài khoản @user.UserName?');">
                            <input type="hidden" name="userId" value="@user.UserId" />
                            <button type="submit" class="btn btn-danger btn-sm">Khóa</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Unlock" onsubmit="return confirm('Xác nhận mở khóa tài khoản @user.UserName?');">
                            <input type="hidden" name="userId" value="@user.UserId" />
                            <button type="submit" class="btn btn-success btn-sm">Mở khóa</button>
                        </form>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
