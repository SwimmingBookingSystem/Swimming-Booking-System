@page
@model SBS.WebApp.Pages.Customer.Profile.IndexModel
@{
    ViewData["Title"] = "Thông tin cá nhân";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <partial name="_ProfileSidebar" />
        </div>
        
        <!-- Content -->
        <div class="col-md-9">
            <div class="ocean-card p-2">
                <div class="card-body p-4">
                    <h4 class="card-title fw-bold text-teal mb-4 border-bottom pb-3">Thông tin cá nhân</h4>
                    
                    @if (!ModelState.IsValid)
                    {
                        <div class="alert alert-danger">
                            <div asp-validation-summary="All"></div>
                        </div>
                    }
                    @if (TempData["SuccessMessage"] != null)
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            @TempData["SuccessMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form method="post">
                        <div class="row mb-3">
                            <div class="col-md-4 text-center mb-4 mb-md-0 d-flex flex-column align-items-center justify-content-center">
                                <div class="position-relative mb-3">
                                    <img id="avatarPreview" src="https://ui-avatars.com/api/?name=@(System.Net.WebUtility.UrlEncode(Model.FullName ?? "User"))&background=00C2E0&color=fff&rounded=true&size=200" alt="Avatar" class="rounded-circle shadow-sm" style="width: 150px; height: 150px; object-fit: cover; border: 4px solid var(--cool-gray);">
                                </div>
                                <p class="text-muted small">Ảnh đại diện được tạo tự động từ tên của bạn.</p>
                            </div>
                            <div class="col-md-8">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Họ và tên</label>
                                    <input asp-for="FullName" class="form-control ocean-input" />
                                    <span asp-validation-for="FullName" class="text-danger"></span>
                                </div>
                                <div class="mb-3">
                                    <label class="form-label fw-bold">Email</label>
                                    <input type="text" class="form-control ocean-input bg-light" value="@Model.Email" readonly disabled />
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Ngày sinh</label>
                                <input asp-for="Dob" type="date" class="form-control ocean-input" />
                                <span asp-validation-for="Dob" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Giới tính</label>
                                <select asp-for="Gender" class="form-select ocean-input">
                                    <option value="">Chọn giới tính</option>
                                    <option value="Nam">Nam</option>
                                    <option value="Nữ">Nữ</option>
                                    <option value="Khác">Khác</option>
                                </select>
                                <span asp-validation-for="Gender" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Địa chỉ</label>
                            <input asp-for="Address" class="form-control ocean-input" />
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="text-end">
                            <button type="submit" class="btn ocean-btn-primary px-5 py-2">Lưu thay đổi</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/UserProfile/profile.js"></script>
}
