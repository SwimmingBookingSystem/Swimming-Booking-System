@startuml
title SBS - Sequence Manager tạo bể bơi

autonumber
actor "Manager" as Manager
boundary "Manager Pool Create\nRazor Page" as UI
control "Manager API helper" as ApiHelper
control "ManagerPoolController" as Controller
control "CloudinaryService" as CloudinaryService
entity "Cloudinary" as Cloudinary
control "CreatePoolCommandValidator" as Validator
control "MediatR / CreatePoolHandler" as Handler
control "UpdatePoolImagesHandler" as ImageHandler
control "UnitOfWork" as UoW
database "SQL Server\nPools / PoolImages" as DB

Manager -> UI: Nhập tên, địa chỉ, giờ mở/đóng,\ndiện tích, mô tả và chọn ảnh

opt Upload ảnh trước khi lưu
    loop Tối đa 10 ảnh
        UI -> ApiHelper: uploadFile(/pools/upload-image, file)
        ApiHelper -> Controller: POST /api/manager/pools/upload-image
        Controller -> CloudinaryService: UploadImageAsync(stream, fileName)
        CloudinaryService -> Cloudinary: Upload image
        Cloudinary --> CloudinaryService: image URL
        CloudinaryService --> Controller: URL
        Controller --> UI: 200 {url}
        UI -> UI: Thêm URL, chọn tối đa 1 ảnh bìa
    end
end

Manager -> UI: Nhấn Lưu bể bơi
UI -> UI: HTML validation\nopeningTime < closingTime
alt Client validation thất bại
    UI --> Manager: Hiển thị lỗi
else Client validation thành công
    UI -> ApiHelper: post(/pools, payload)\n(payload UI hiện tại chưa chứa images)
    ApiHelper -> Controller: POST /api/manager/pools\nJWT role = Manager
    Controller -> Controller: Parse OpeningTime, ClosingTime
    alt Parse time thất bại
        Controller --> UI: 400 Bad Request
    else Parse thành công
        Controller -> Validator: Validate CreatePoolCommand
        alt Tên/địa chỉ/giờ/ảnh không hợp lệ
            Validator --> Controller: validation errors
            Controller --> UI: 400 + errors
        else Hợp lệ
            Validator --> Controller: Valid
            Controller -> Handler: MediatR.Send(command)
            Handler -> Handler: StandardCapacity = floor(Area / 2.5)\nStatus = Active\nCreatedAt = UTC now
            Handler -> UoW: Add Pool + SaveChanges
            UoW -> DB: INSERT Pools
            DB --> UoW: generated PoolId
            UoW --> Handler: Saved
            Handler --> Controller: poolId, poolName, status
            Controller --> UI: 201 Created

            opt UI có ảnh đã upload
                UI -> ApiHelper: put(/pools/{poolId}/images, images)
                ApiHelper -> Controller: PUT /api/manager/pools/{id}/images
                Controller -> ImageHandler: MediatR.Send(UpdatePoolImagesCommand)
                ImageHandler -> DB: Replace/INSERT PoolImages
                DB --> ImageHandler: Saved
                ImageHandler --> UI: 200 OK
            end
            UI --> Manager: Thông báo thành công\nRedirect /Manager/Pools
        end
    end
end

note over Manager,Controller
Implementation hiện tại chỉ cấp endpoint tạo bể cho role Manager,
không phải Admin.
end note
@enduml

