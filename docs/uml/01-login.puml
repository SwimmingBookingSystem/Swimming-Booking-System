@startuml
title SBS - Sequence đăng nhập

autonumber
actor "Người dùng" as User
boundary "Login Razor Page\n(JavaScript/AJAX)" as UI
control "AuthController" as Controller
control "LoginCommandValidator" as Validator
control "MediatR / LoginCommandHandler" as Handler
control "AuthService" as AuthService
control "ASP.NET Identity\nUserManager" as Identity
database "SQL Server\nAspNetUsers / Roles" as DB
control "TokenService" as TokenService
database "Redis cache" as Redis

User -> UI: Nhập userName, password
UI -> Controller: POST /api/Auth/login\n{userName, password}\nwithCredentials = true
Controller -> Validator: ValidateAsync(LoginCommand)

alt Dữ liệu rỗng/không hợp lệ
    Validator --> Controller: Validation errors
    Controller --> UI: 400 Bad Request
    UI --> User: Hiển thị lỗi
else Dữ liệu hợp lệ
    Validator --> Controller: Valid
    Controller -> Handler: Send(LoginCommand)
    Handler -> AuthService: LoginAsync(userName, password)
    AuthService -> Identity: FindByNameAsync(userName)
    Identity -> DB: SELECT user
    DB --> Identity: AppUser hoặc null
    Identity --> AuthService: AppUser hoặc null

    alt Không có user / sai mật khẩu
        opt User tồn tại
            AuthService -> Identity: CheckPasswordAsync(user, password)
            Identity -> DB: Xác minh password hash
            DB --> Identity: false
            Identity --> AuthService: false
        end
        AuthService --> Handler: Failure
        Handler --> Controller: AuthResultDto.Failure
        Controller --> UI: 400 + message
        UI --> User: Thông báo đăng nhập thất bại
    else Tài khoản không Active
        AuthService --> Handler: Failure("tài khoản bị khóa/ngừng")
        Handler --> Controller: Failure
        Controller --> UI: 400 + message
    else Email chưa xác thực
        AuthService --> Handler: Failure("chưa xác thực email")
        Handler --> Controller: Failure
        Controller --> UI: 400 + message
    else Thông tin hợp lệ
        AuthService -> Identity: CheckPasswordAsync(user, password)
        Identity -> DB: Xác minh password hash
        DB --> Identity: true
        Identity --> AuthService: true
        AuthService -> Identity: GetRolesAsync(user)
        Identity -> DB: SELECT roles
        DB --> Identity: Role list
        Identity --> AuthService: Role list
        AuthService -> TokenService: GenerateAccessToken(user, roles)
        TokenService --> AuthService: JWT accessToken + jwtId
        AuthService -> TokenService: GenerateRefreshToken()
        TokenService --> AuthService: random 64-byte token
        AuthService -> Redis: SET refreshToken:{token}\nRefreshToken, TTL theo expiry
        Redis --> AuthService: OK
        AuthService --> Handler: AuthResultDto.Success
        Handler --> Controller: user info + tokens + role
        Controller -> Controller: Ghi HttpOnly cookies:\naccessToken, refreshToken\nGhi cookies đọc được bởi JS:\nrole, fullName, userName, userId
        Controller --> UI: 200 OK + id, userName, fullName, role, expiryDate
        alt role = Admin
            UI --> User: Redirect /Admin/users
        else role = Manager
            UI --> User: Redirect /Manager/Dashboard
        else role = Staff
            UI --> User: Redirect /Staff/CheckIn
        else role = Customer
            UI --> User: Redirect /
        end
    end
end

note over Controller,Redis
Access token được JWT Bearer middleware đọc từ cookie "accessToken".
Refresh token được lưu trong Redis, không lưu vào bảng RefreshTokens ở luồng login hiện tại.
end note
@enduml

