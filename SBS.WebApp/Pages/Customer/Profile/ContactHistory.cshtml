@page
@model SBS.WebApp.Pages.Customer.Profile.ContactHistoryModel
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    ViewData["Title"] = "Lịch sử gửi liên hệ";
    Layout = "~/Pages/Shared/_Layout.cshtml";
}

<div class="container my-5">
    <div class="row">
        <!-- Sidebar -->
        <div class="col-md-3 mb-4">
            <partial name="_ProfileSidebar" />
        </div>
        
        <!-- Content -->
        <div class="col-md-9">
            <div class="ocean-card p-2">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center border-bottom pb-3 mb-4">
                        <h4 class="mb-0 fw-bold text-teal"><i class="bi bi-envelope-paper me-2"></i> Lịch sử gửi liên hệ</h4>
                    </div>

                    <div id="contactHistoryContainer" class="accordion">
                        <!-- JS will render cards here -->
                    </div>

                    <div id="paginationContainer" class="d-flex justify-content-center mt-4">
                        <!-- JS will render pagination here -->
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/UserProfile/contact-history.js"></script>
}
