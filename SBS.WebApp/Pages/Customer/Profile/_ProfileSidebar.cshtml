<div class="card mb-4 shadow-sm border-0">
    <div class="card-header bg-primary text-white text-center py-3">
        <h5 class="mb-0">Tài khoản của tôi</h5>
    </div>
    <div class="list-group list-group-flush">
        <a href="/Customer/Profile" class="list-group-item list-group-item-action @((ViewContext.RouteData.Values["Page"]?.ToString() ?? "").EndsWith("/Index") ? "active font-weight-bold" : "")">
            <i class="bi bi-person-fill me-2"></i> Thông tin cá nhân
        </a>
        <a href="/Customer/Profile/Bookings" class="list-group-item list-group-item-action @((ViewContext.RouteData.Values["Page"]?.ToString() ?? "").EndsWith("/Bookings") ? "active font-weight-bold" : "")">
            <i class="bi bi-clock-history me-2"></i> Lịch sử đặt vé
        </a>
        <a href="/Customer/Profile/ChangePassword" class="list-group-item list-group-item-action @((ViewContext.RouteData.Values["Page"]?.ToString() ?? "").EndsWith("/ChangePassword") ? "active font-weight-bold" : "")">
            <i class="bi bi-shield-lock-fill me-2"></i> Đổi mật khẩu
        </a>
    </div>
</div>
