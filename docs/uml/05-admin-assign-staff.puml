@startuml
title SBS - Sequence Admin phân công Staff cho bể bơi

autonumber
actor "Admin" as Admin
boundary "Admin Employees\nRazor Page" as UI
control "AdminUsersController" as Controller
control "FluentValidator" as Validator
control "MediatR" as Mediator
control "CreateStaff/UpdateUser Handler" as Handler
control "AdminService" as AdminService
control "ASP.NET Identity UserManager" as Identity
database "ReadDbContext" as ReadDB
database "ApplicationDbContext" as WriteDB

Admin -> UI: Mở form tạo/sửa nhân viên
par Tải danh sách bể Active
    UI -> Controller: GET /api/admin/users/pools
    Controller -> Mediator: Send(GetAdminPoolsQuery)
    Mediator -> AdminService: GetPoolsAsync()
    AdminService -> ReadDB: SELECT Pools WHERE Status=Active
    ReadDB --> AdminService: Pool list
    AdminService --> UI: Pool list
else Khi sửa: tải user và assignment
    UI -> Controller: GET /api/admin/users
    Controller -> Mediator: Send(GetUsersQuery)
    Mediator -> AdminService: GetUsersAsync()
    AdminService -> ReadDB: JOIN Users, Roles, PoolStaffAssignments
    ReadDB --> AdminService: Users + PoolId
    AdminService --> UI: User list
end

alt Tạo staff mới và phân công ngay
    Admin -> UI: Nhập hồ sơ, chọn PoolId, Submit
    UI -> Controller: POST /api/admin/users/create-staff
    Controller -> Validator: Validate CreateStaffCommand
    alt Validation lỗi
        Controller --> UI: 400 + errors
    else Hợp lệ
        Controller -> Mediator: Send(CreateStaffCommand)
        Mediator -> Handler: Handle(command)
        Handler -> AdminService: CreateStaffAsync(dto, poolId)
        AdminService -> Identity: CreateAsync(AppUser, password)
        Identity -> WriteDB: INSERT AspNetUsers
        WriteDB --> Identity: Created
        AdminService -> Identity: AddToRoleAsync(user, "Staff")
        Identity -> WriteDB: INSERT AspNetUserRoles
        AdminService -> ReadDB: Pool tồn tại?
        ReadDB --> AdminService: true/false
        alt Pool không tồn tại
            AdminService --> UI: 400 - bể không tồn tại
        else Pool tồn tại
            AdminService -> ReadDB: Pool đã có assignment?
            ReadDB --> AdminService: true/false
            alt Bể đã có staff phụ trách
                AdminService --> UI: 400 - bể đã được phân công
            else Bể còn trống
                AdminService -> WriteDB: INSERT PoolStaffAssignment\n(poolId, staffId, assignedAt)
                WriteDB --> AdminService: Saved
                AdminService --> Handler: Success
                Handler --> Controller: Success
                Controller --> UI: 200 OK
                UI --> Admin: Tạo và phân công thành công
            end
        end
    end
else Phân công lại/bỏ phân công staff hiện có
    Admin -> UI: Chọn PoolId mới hoặc "Không phân công"
    UI -> Controller: PUT /api/admin/users/{userId}\nUpdateUserCommand
    Controller -> Validator: Validate command và khớp userId
    Controller -> Mediator: Send(UpdateUserCommand)
    Mediator -> Handler: Handle(command)
    Handler -> AdminService: UpdateUserAsync(userId, dto)
    AdminService -> Identity: FindById + UpdateAsync(profile)
    Identity -> WriteDB: UPDATE AspNetUsers
    AdminService -> WriteDB: Tìm assignment hiện tại theo staffId
    WriteDB --> AdminService: Assignment hoặc null

    alt PoolId có giá trị
        AdminService -> ReadDB: Kiểm tra Pool tồn tại
        AdminService -> ReadDB: Kiểm tra Pool đã có staff khác
        alt Pool không tồn tại/đã có staff khác
            AdminService --> UI: 400 + lý do
        else Hợp lệ và đã có assignment khác Pool
            AdminService -> WriteDB: UPDATE assignment.PoolId
            WriteDB --> AdminService: Saved
            AdminService --> UI: 200 OK
        else Hợp lệ và chưa có assignment
            AdminService -> WriteDB: INSERT PoolStaffAssignment
            WriteDB --> AdminService: Saved
            AdminService --> UI: 200 OK
        else Đã gán đúng PoolId
            AdminService --> UI: 200 OK (không đổi assignment)
        end
    else PoolId = null
        opt Có assignment hiện tại
            AdminService -> WriteDB: DELETE PoolStaffAssignment
            WriteDB --> AdminService: Saved
        end
        AdminService --> UI: 200 OK
    end
    UI --> Admin: Hiển thị kết quả cập nhật
end

note over AdminService,WriteDB
Unique index trên PoolStaffAssignments.PoolId bảo đảm mỗi bể tối đa 1 staff.
AssignedByAdminId hiện chưa được gán trong AdminService.
end note

note over Identity,ReadDB
CreateStaff/UpdateUser hiện không dùng một transaction bao trùm Identity và assignment.
Lỗi phân công có thể xảy ra sau khi tài khoản/hồ sơ đã được ghi.
end note
@enduml

