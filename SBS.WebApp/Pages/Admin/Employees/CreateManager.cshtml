@page
@model SBS.WebApp.Pages.Admin.Employees.CreateManagerModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Thêm Quản lý";
    ViewData["Breadcrumb"] = "Quản trị / Nhân sự / Thêm quản lý";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">
                    <i class="fa-solid fa-user-tie text-warning me-2"></i>Thêm quản lý mới
                </h5>
                <p class="text-muted small mt-1 mb-0">Tạo tài khoản quản lý cho hệ thống.</p>
            </div>
            <div class="card-body p-4">
                <form id="createManagerForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="userName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="email" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="fullName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Số điện thoại</label>
                            <input type="text" class="form-control" id="phoneNumber" placeholder="0xxxxxxxxx" pattern="^0\d{9,10}$" title="Số điện thoại phải bắt đầu bằng 0 và có 10-11 số">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Mật khẩu <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="password" required>
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                    <i class="fa-regular fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium small text-muted">Giới tính</label>
                            <select class="form-select" id="gender">
                                <option value="">---</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium small text-muted">Ngày sinh</label>
                            <input type="date" class="form-control" id="dob" max="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium small text-muted">Địa chỉ</label>
                            <input type="text" class="form-control" id="address">
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-warning fw-semibold px-4" id="btnSubmit">
                            <i class="fa-solid fa-check me-2"></i>Tạo quản lý
                        </button>
                        <a href="/Admin/Employees" class="btn btn-light border fw-semibold px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#createManagerForm').on('submit', async function(e) {
                e.preventDefault();
                const $btn = $('#btnSubmit');
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...');

                const data = {
                    userName: $('#userName').val().trim(),
                    email: $('#email').val().trim(),
                    fullName: $('#fullName').val().trim(),
                    phoneNumber: $('#phoneNumber').val().trim() || null,
                    password: $('#password').val(),
                    gender: $('#gender').val() || null,
                    dob: $('#dob').val() || null,
                    address: $('#address').val().trim() || null
                };

                try {
                    await api.post('/users/create-manager', data);
                    toastr.success('Tạo quản lý thành công.');
                    setTimeout(() => window.location.href = '/Admin/Employees', 1000);
                } catch (e) {
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-check me-2"></i>Tạo quản lý');
                }
            });
        });

        $('#togglePassword').click(function() {
            const input = $('#password');
            const icon = $(this).find('i');
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
                icon.removeClass('fa-eye').addClass('fa-eye-slash');
            } else {
                input.attr('type', 'password');
                icon.removeClass('fa-eye-slash').addClass('fa-eye');
            }
        });
    </script>
}
