@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manager Dashboard</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Toastr for Notifications -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- Flatpickr for 24h Time format -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <!-- Manager Custom CSS -->
    <link rel="stylesheet" href="~/css/manager.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav id="sidebar">
        <a href="/Manager/Dashboard" class="brand">
            <i class="fa-solid fa-water"></i> SBS Manager
        </a>
        <div class="nav flex-column">
            @{ var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? ""; }
            <a class="nav-link @(currentPage.StartsWith("/Manager/Dashboard") ? "active" : "")" href="/Manager/Dashboard">
                <i class="fa-solid fa-chart-pie w-20px"></i> Tổng quan
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Pools") ? "active" : "")" href="/Manager/Pools">
                <i class="fa-solid fa-swimming-pool w-20px"></i> Bể bơi
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Slots") ? "active" : "")" href="/Manager/Slots">
                <i class="fa-regular fa-clock w-20px"></i> Khung giờ
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Tickets") ? "active" : "")" href="/Manager/Tickets">
                <i class="fa-solid fa-ticket w-20px"></i> Loại vé
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Pricing") ? "active" : "")" href="/Manager/Pricing">
                <i class="fa-solid fa-tags w-20px"></i> Bảng giá
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div id="content">
        <!-- Topbar -->
        <div class="topbar">
            <div class="breadcrumb mb-0 fw-medium text-muted">
                @ViewData["Breadcrumb"]
            </div>
            <div class="d-flex align-items-center gap-3">
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle rounded-pill border-0 shadow-sm" type="button" data-bs-toggle="dropdown" id="userMenuBtn">
                        <img id="userAvatar" src="https://ui-avatars.com/api/?name=User&background=0D8ABC&color=fff" class="rounded-circle me-2" width="32" height="32" />
                        <span id="userNameDisplay">Đang tải...</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        @* <li><a class="dropdown-item" href="#">Hồ sơ</a></li> *@
                        @* <li><hr class="dropdown-divider"></li> *@
                        <li><a class="dropdown-item text-danger" href="#" onclick="logout(); return false;">Đăng xuất</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <!-- Global Loader -->
    <div id="global-loader">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <!-- Flatpickr JS -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        // Removed Flatpickr time initialization to use native browser time picker
    </script>
    <script>
        // Helper đọc cookie
        function getCookie(name) {
            let value = "; " + document.cookie;
            let parts = value.split("; " + name + "=");
            if (parts.length === 2) return parts.pop().split(";").shift();
            return null;
        }

        // --- 1. KIỂM TRA XÁC THỰC (AUTHENTICATION) ---
        const userRole = getCookie('role');
        const fullName = decodeURIComponent(getCookie('fullName') || getCookie('userName') || 'Manager');

        // Nếu không có role, hoặc role không phải Manager -> Đẩy về trang Login
        if (!userRole || userRole.toLowerCase() !== 'manager') {
            window.location.href = '/Auth/Login';
        }

        // Hàm Đăng xuất
        async function logout() {
            try {
                // Gọi API Đăng xuất để xóa Refresh Token trong Database và xóa Cookie HttpOnly
                const baseUrl = '@Configuration["ApiBaseUrl"]';
                await $.ajax({
                    url: baseUrl + '/api/auth/logout',
                    type: 'POST',
                    xhrFields: { withCredentials: true }
                });
            } catch (error) {
                console.error("Lỗi khi gọi API Đăng xuất:", error);
            } finally {
                // Dự phòng: Xóa thủ công các Cookie lưu ở Client
                const expiredDate = "Thu, 01 Jan 1970 00:00:00 UTC";
                const cookiesToClear = ["accessToken", "refreshToken", "role", "fullName", "userName", "userId"];
                
                cookiesToClear.forEach(cookie => {
                    document.cookie = `${cookie}=; expires=${expiredDate}; path=/; domain=localhost;`;
                    document.cookie = `${cookie}=; expires=${expiredDate}; path=/;`; // Cho trường hợp không có domain
                });
                
                window.location.href = '/Index';
            }
        }

        // --- 2. HIỂN THỊ THÔNG TIN NGƯỜI DÙNG ---
        $(document).ready(function() {
            $('#userNameDisplay').text(fullName);
            $('#userAvatar').attr('src', `https://ui-avatars.com/api/?name=${encodeURIComponent(fullName)}&background=0D8ABC&color=fff`);
        });

        // --- 3. CẤU HÌNH GỌI API (MANAGER API INTERCEPTOR) ---
        toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "3000" };
        
        window.API_BASE_URL = '@Configuration["ApiBaseUrl"]';

        const api = {
            baseURL: window.API_BASE_URL + '/api/manager',
            request: function(method, url, data) {
                return new Promise((resolve, reject) => {
                    $('#global-loader').css('display', 'flex');
                    
                    const role = getCookie('role');
                    if (!role) {
                        $('#global-loader').hide();
                        logout();
                        reject(new Error("No active session available"));
                        return;
                    }

                    const headers = { 
                        'Content-Type': 'application/json'
                    };
                    
                    $.ajax({
                        url: this.baseURL + url, 
                        type: method, 
                        headers: headers,
                        xhrFields: {
                            withCredentials: true // RẤT QUAN TRỌNG: Tự động gửi kèm Cookie của API
                        },
                        data: data ? JSON.stringify(data) : null,
                        success: function(response) { 
                            $('#global-loader').hide(); 
                            resolve(response); 
                        },
                        error: function(xhr) {
                            $('#global-loader').hide();
                            console.error("API Error: ", xhr);
                            const status = xhr.status;
                            let dataObj = {};
                            try { dataObj = JSON.parse(xhr.responseText); } catch(e) {}
                            
                            if (status === 401) {
                                toastr.error('Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.');
                                setTimeout(() => logout(), 1500);
                            } else if (status === 403) {
                                toastr.error('Bạn không có quyền thực hiện thao tác này.');
                            } else if (status === 400 || status === 404 || status === 422) {
                                const errs = dataObj.errors || dataObj.Errors;
                                const msg = dataObj.message || dataObj.Message;
                                const title = dataObj.title || dataObj.Title;
                                
                                if (errs && Array.isArray(errs) && errs.length > 0) {
                                    errs.forEach(err => toastr.error(err));
                                } else if (errs && typeof errs === 'object') {
                                    Object.values(errs).forEach(errArr => {
                                        if (Array.isArray(errArr)) errArr.forEach(err => toastr.error(err));
                                        else toastr.error(errArr); 
                                    });
                                } else if (msg) {
                                    toastr.error(msg);
                                } else if (title) {
                                    toastr.error(title);
                                } else {
                                    toastr.error('Lỗi (' + status + '): ' + (xhr.responseText ? xhr.responseText.substring(0,100) : 'Yêu cầu không hợp lệ.'));
                                }
                            } else if (status === 500) {
                                toastr.error('Đã xảy ra lỗi hệ thống (500). Vui lòng thử lại sau.');
                            } else {
                                toastr.error('Lỗi máy chủ không xác định.');
                            }
                            reject(xhr);
                        }
                    });
                });
            },
            get: function(url) { return this.request('GET', url); },
            post: function(url, data) { return this.request('POST', url, data); },
            put: function(url, data) { return this.request('PUT', url, data); },
            patch: function(url, data) { return this.request('PATCH', url, data); },
            delete: function(url) { return this.request('DELETE', url); },
            uploadFile: function(url, file) {
                return new Promise((resolve, reject) => {
                    $('#global-loader').css('display', 'flex');
                    const formData = new FormData();
                    formData.append('file', file);
                    $.ajax({
                        url: this.baseURL + url,
                        type: 'POST',
                        data: formData,
                        processData: false,
                        contentType: false,
                        xhrFields: { withCredentials: true },
                        success: function(response) {
                            $('#global-loader').hide();
                            resolve(response);
                        },
                        error: function(xhr) {
                            $('#global-loader').hide();
                            console.error("Upload Error: ", xhr);
                            let errorMsg = 'Lỗi khi tải ảnh lên. Vui lòng thử lại.';
                            try {
                                const dataObj = JSON.parse(xhr.responseText);
                                if (dataObj.message) errorMsg = dataObj.message;
                                else if (dataObj.Message) errorMsg = dataObj.Message;
                                else if (typeof dataObj === 'string') errorMsg = dataObj;
                            } catch(e) {
                                if (xhr.responseText) errorMsg = xhr.responseText.substring(0, 100);
                            }
                            toastr.error(errorMsg);
                            reject(xhr);
                        }
                    });
                });
            }
        };
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
