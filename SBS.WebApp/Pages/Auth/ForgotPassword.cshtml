@page
@model SBS.WebApp.Pages.Auth.ForgotPasswordModel
@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Khôi phục mật khẩu - Swimming Booking System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    
    <!-- Thư viện SweetAlert2 cho Popup đẹp mắt -->
    <link href="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.7/dist/sweetalert2.min.css" rel="stylesheet">

    <style>
        :root {
            --primary-color: #0284c7;
            --primary-hover: #0369a1;
            --bg-gradient: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 50%, #7dd3fc 100%);
            --card-bg: rgba(255, 255, 255, 0.88);
            --text-color: #0f172a;
            --shadow-premium: 0 20px 40px -15px rgba(2, 132, 199, 0.25), 0 1px 3px rgba(0, 0, 0, 0.05);
        }

        body {
            background-image: linear-gradient(rgba(14, 165, 233, 0.1), rgba(15, 23, 42, 0.4)), url('/images/swimming_pool_bg.png');
            background-size: cover;
            background-position: center;
            background-repeat: no-repeat;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Inter', sans-serif;
            color: var(--text-color);
            margin: 0;
            padding: 40px 15px;
            position: relative;
        }

        .auth-container {
            width: 100%;
            max-width: 480px;
            z-index: 10;
        }

        .auth-card {
            background: var(--card-bg);
            border-radius: 28px;
            border: 1px solid rgba(255, 255, 255, 0.6);
            box-shadow: var(--shadow-premium);
            backdrop-filter: blur(16px);
            padding: 45px 40px;
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
        }

        .auth-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 30px 60px -20px rgba(2, 132, 199, 0.35);
        }

        .brand-icon-wrapper {
            width: 70px;
            height: 70px;
            background: linear-gradient(135deg, #0ea5e9 0%, #2563eb 100%);
            border-radius: 22px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px auto;
            box-shadow: 0 8px 16px rgba(2, 132, 199, 0.2);
            color: white;
            font-size: 2.2rem;
            animation: pulse-wave 3s infinite ease-in-out;
        }

        @@keyframes pulse-wave {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .brand-title {
            color: #0369a1;
            font-weight: 800;
            font-size: 1.8rem;
            text-align: center;
            margin-bottom: 5px;
            letter-spacing: -0.5px;
        }

        .brand-subtitle {
            font-size: 0.98rem;
            color: #64748b;
            text-align: center;
            margin-bottom: 35px;
            line-height: 1.5;
        }

        .form-group-custom {
            margin-bottom: 20px;
            position: relative;
        }

        .form-label {
            font-weight: 600;
            font-size: 0.9rem;
            color: #334155;
            margin-bottom: 8px;
            display: block;
        }

        .input-group-custom {
            position: relative;
        }

        .input-icon-left {
            position: absolute;
            left: 16px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.1rem;
            z-index: 5;
        }

        .form-control {
            border-radius: 14px;
            padding: 13px 15px 13px 44px;
            border: 1.5px solid #e2e8f0;
            font-size: 0.95rem;
            font-family: 'Inter', sans-serif;
            background-color: rgba(248, 250, 252, 0.8);
            transition: all 0.3s ease;
            color: var(--text-color);
        }

        .form-control:focus {
            background-color: #fff;
            border-color: var(--primary-color);
            box-shadow: 0 0 0 4px rgba(2, 132, 199, 0.12);
        }

        .password-container {
            position: relative;
        }

        .password-toggle {
            position: absolute;
            right: 16px;
            top: 50%;
            transform: translateY(-50%);
            border: none;
            background: none;
            color: #94a3b8;
            cursor: pointer;
            padding: 0;
            font-size: 1.2rem;
            z-index: 5;
            transition: color 0.2s ease;
        }

        .password-toggle:hover {
            color: var(--primary-color);
        }

        .btn-auth {
            background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%);
            border: none;
            border-radius: 14px;
            padding: 14px;
            font-weight: 700;
            font-size: 1.05rem;
            color: white;
            transition: all 0.3s ease;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.25);
            cursor: pointer;
            margin-top: 15px;
        }

        .btn-auth:hover {
            background: linear-gradient(135deg, #0284c7 0%, #0369a1 100%);
            transform: scale(1.01);
            box-shadow: 0 6px 20px rgba(2, 132, 199, 0.35);
        }

        .btn-auth:disabled {
            background: #93c5fd;
            cursor: not-allowed;
            transform: none;
            box-shadow: none;
        }

        .back-link {
            text-align: center;
            margin-top: 25px;
            font-size: 0.95rem;
        }

        .back-link a {
            color: var(--primary-color);
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .back-link a:hover {
            color: var(--primary-hover);
            text-decoration: underline;
        }

        /* Waves Animation Styling */
        .waves-container {
            position: absolute;
            bottom: 0;
            width: 100%;
            height: 150px;
            left: 0;
            z-index: 1;
            pointer-events: none;
        }

        .waves {
            position: relative;
            width: 100%;
            height: 150px;
            margin-bottom: -7px;
        }

        .parallax > use {
            animation: move-forever 20s cubic-bezier(.55,.5,.45,.5) infinite;
        }
        .parallax > use:nth-child(1) { animation-delay: -2s; animation-duration: 9s; }
        .parallax > use:nth-child(2) { animation-delay: -3s; animation-duration: 12s; }
        .parallax > use:nth-child(3) { animation-delay: -4s; animation-duration: 15s; }
        .parallax > use:nth-child(4) { animation-delay: -5s; animation-duration: 25s; }

        @@keyframes move-forever {
            0% { transform: translate3d(-90px,0,0); }
            100% { transform: translate3d(85px,0,0); }
        }

        .otp-input-container {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin: 20px 0;
        }

        .otp-digit {
            width: 45px;
            height: 50px;
            text-align: center;
            font-size: 1.3rem;
            font-weight: 700;
            border: 2px solid #e2e8f0;
            border-radius: 10px;
            background-color: rgba(248, 250, 252, 0.8);
            color: var(--text-color);
            transition: all 0.3s ease;
        }

        .otp-digit:focus {
            outline: none;
            border-color: var(--primary-color);
            background-color: #fff;
            box-shadow: 0 0 0 4px rgba(2, 132, 199, 0.12);
        }
        
        /* Tùy chỉnh font cho SweetAlert2 */
        .swal2-popup {
            font-family: 'Inter', sans-serif !important;
            border-radius: 20px !important;
        }
        .swal2-confirm {
            border-radius: 12px !important;
            font-weight: 600 !important;
        }
    </style>
</head>
<body>

    <div class="auth-container">
        <div class="auth-card">
            <div class="brand-icon-wrapper">
                <i class="bi bi-shield-lock"></i>
            </div>
            
            <h2 class="brand-title" id="page-title">Quên mật khẩu</h2>
            <div class="brand-subtitle" id="page-subtitle">Nhập email của bạn để nhận mã khôi phục</div>

            <!-- BƯỚC 1: YÊU CẦU LẤY LẠI MẬT KHẨU -->
            <form id="forgot-form" novalidate>
                <div class="form-group-custom">
                    <label for="email" class="form-label">Email đã đăng ký</label>
                    <div class="input-group-custom">
                        <i class="bi bi-envelope-fill input-icon-left"></i>
                        <input type="email" class="form-control" id="email" placeholder="example@gmail.com" required />
                    </div>
                </div>

                <button type="submit" class="btn-auth" id="forgot-submit-btn">
                    <span id="forgot-btn-text">Nhận mã OTP khôi phục</span>
                    <span class="spinner-border spinner-border-sm ms-2 d-none" id="forgot-btn-spinner" role="status" aria-hidden="true"></span>
                </button>
            </form>

            <!-- BƯỚC 2: XÁC THỰC MÃ OTP (Mặc định ẩn) -->
            <form id="otp-form" class="d-none" novalidate>
                <div class="text-center mb-3">
                    <p class="text-muted" style="font-size: 0.9rem;">Mã xác thực đã được gửi tới <strong id="target-email-text" class="text-primary"></strong></p>
                </div>

                <label class="form-label text-center d-block">Nhập mã OTP</label>
                <div class="otp-input-container">
                    <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" required />
                    <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" required disabled />
                    <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" required disabled />
                    <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" required disabled />
                    <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" required disabled />
                    <input type="text" class="otp-digit" maxlength="1" pattern="[0-9]" inputmode="numeric" required disabled />
                </div>

                <div class="text-center mt-2 mb-3">
                    <span id="resend-timer-text" class="text-muted" style="font-size: 0.85rem;">Không nhận được mã? Gửi lại sau: <strong id="countdown">30s</strong></span>
                    <span id="resend-action-container" class="d-none">
                        <span class="text-muted" style="font-size: 0.85rem;">Không nhận được mã? </span>
                        <a href="javascript:void(0)" id="resend-otp-btn" style="font-size: 0.85rem; color: var(--primary-color); font-weight: 600; text-decoration: none;">Gửi lại mã OTP</a>
                    </span>
                    <span class="spinner-border spinner-border-sm text-primary ms-1 d-none" id="resend-spinner" role="status" aria-hidden="true" style="width: 1rem; height: 1rem;"></span>
                </div>

                <button type="submit" class="btn-auth" id="otp-submit-btn">
                    <span id="otp-btn-text">Xác nhận mã OTP</span>
                    <span class="spinner-border spinner-border-sm ms-2 d-none" id="otp-btn-spinner" role="status" aria-hidden="true"></span>
                </button>
            </form>

            <!-- BƯỚC 3: ĐẶT LẠI MẬT KHẨU (Mặc định ẩn) -->
            <form id="reset-form" class="d-none" novalidate>
                <div class="form-group-custom mt-2">
                    <label for="new-password" class="form-label">Mật khẩu mới</label>
                    <div class="input-group-custom password-container">
                        <i class="bi bi-lock-fill input-icon-left"></i>
                        <input type="password" class="form-control" id="new-password" placeholder="Nhập mật khẩu mới" required />
                        <button type="button" class="password-toggle toggle-pass" data-target="new-password">
                            <i class="bi bi-eye pass-icon"></i>
                        </button>
                    </div>
                </div>

                <div class="form-group-custom">
                    <label for="confirm-password" class="form-label">Xác nhận mật khẩu mới</label>
                    <div class="input-group-custom password-container">
                        <i class="bi bi-shield-check input-icon-left"></i>
                        <input type="password" class="form-control" id="confirm-password" placeholder="Nhập lại mật khẩu mới" required />
                        <button type="button" class="password-toggle toggle-pass" data-target="confirm-password">
                            <i class="bi bi-eye pass-icon"></i>
                        </button>
                    </div>
                </div>

                <button type="submit" class="btn-auth" id="reset-submit-btn">
                    <span id="reset-btn-text">Đặt lại mật khẩu</span>
                    <span class="spinner-border spinner-border-sm ms-2 d-none" id="reset-btn-spinner" role="status" aria-hidden="true"></span>
                </button>
            </form>

            <div class="back-link">
                <a href="/Auth/Login"><i class="bi bi-arrow-left"></i> Quay lại đăng nhập</a>
            </div>
        </div>
    </div>

    <!-- Background Sóng nước -->
    <div class="waves-container">
        <svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
             viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
            <defs>
                <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18v44h-352z" />
            </defs>
            <g class="parallax">
                <use xlink:href="#gentle-wave" x="48" y="0" fill="rgba(2, 132, 199, 0.2)" />
                <use xlink:href="#gentle-wave" x="48" y="3" fill="rgba(2, 132, 199, 0.12)" />
                <use xlink:href="#gentle-wave" x="48" y="5" fill="rgba(224, 247, 255, 0.45)" />
                <use xlink:href="#gentle-wave" x="48" y="7" fill="rgba(224, 247, 255, 0.85)" />
            </g>
        </svg>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11.10.7/dist/sweetalert2.all.min.js"></script>
    
    <script>
        $(document).ready(function() {
            const apiBaseUrl = '@Configuration["ApiBaseUrl"]';
            let resetEmail = "";
            let verifiedOtp = "";
            let resendTimer = null;

            // Hàm đếm ngược
            function startResendTimer() {
                let seconds = 30;
                $('#resend-action-container').addClass('d-none');
                $('#resend-timer-text').removeClass('d-none');
                $('#countdown').text(seconds + 's');
                
                clearInterval(resendTimer);
                resendTimer = setInterval(function() {
                    seconds--;
                    $('#countdown').text(seconds + 's');
                    
                    if (seconds <= 0) {
                        clearInterval(resendTimer);
                        $('#resend-timer-text').addClass('d-none');
                        $('#resend-action-container').removeClass('d-none');
                    }
                }, 1000);
            }

            // Gửi lại mã OTP
            $('#resend-otp-btn').click(function() {
                if ($('#resend-spinner').hasClass('d-none') === false) return;

                $('#resend-action-container').addClass('d-none');
                $('#resend-spinner').removeClass('d-none');

                $.ajax({
                    url: `${apiBaseUrl}/api/Auth/forgot-password`, // Dùng lại API forgot-password để gửi mail OTP khôi phục
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: resetEmail }),
                    success: function(response) {
                        $('#resend-spinner').addClass('d-none');
                        showSuccess("Đã gửi lại mã OTP khôi phục mật khẩu vào email của bạn!");
                        startResendTimer();
                        
                        // Clear các ô OTP đang nhập dở
                        $('.otp-digit').val('').prop('disabled', true);
                        $('.otp-digit').first().prop('disabled', false).focus();
                    },
                    error: function(xhr) {
                        $('#resend-spinner').addClass('d-none');
                        $('#resend-action-container').removeClass('d-none');
                        
                        let errorMsg = 'Không thể gửi lại mã OTP.';
                        if (xhr.responseJSON && xhr.responseJSON.errors) {
                            errorMsg = xhr.responseJSON.errors.join('<br>');
                        }
                        showError(errorMsg);
                    }
                });
            });

            // Ẩn/Hiện mật khẩu
            $('.toggle-pass').click(function() {
                const targetId = $(this).attr('data-target');
                const passwordInput = $(`#${targetId}`);
                const toggleIcon = $(this).find('.pass-icon');
                
                if (passwordInput.attr('type') === 'password') {
                    passwordInput.attr('type', 'text');
                    toggleIcon.removeClass('bi-eye').addClass('bi-eye-slash');
                } else {
                    passwordInput.attr('type', 'password');
                    toggleIcon.removeClass('bi-eye-slash').addClass('bi-eye');
                }
            });

            // SweetAlert Helpers
            function showError(message) {
                Swal.fire({
                    icon: 'error',
                    title: 'Lỗi',
                    html: message,
                    confirmButtonColor: '#0284c7'
                });
            }

            function showSuccess(message, callback) {
                Swal.fire({
                    icon: 'success',
                    title: 'Thành công!',
                    text: message,
                    confirmButtonColor: '#0284c7',
                    timer: 2000,
                    timerProgressBar: true
                }).then((result) => {
                    if (callback) callback();
                });
            }

            // UI Loading state helpers
            function setBtnLoading(btnId, isLoading) {
                const btn = $(`#${btnId}`);
                const text = $(`#${btnId.replace('-btn', '-text')}`);
                const spinner = $(`#${btnId.replace('-btn', '-spinner')}`);
                
                if (isLoading) {
                    text.addClass('opacity-50');
                    spinner.removeClass('d-none');
                    btn.prop('disabled', true);
                } else {
                    text.removeClass('opacity-50');
                    spinner.addClass('d-none');
                    btn.prop('disabled', false);
                }
            }

            // OTP Input Logic
            $('.otp-digit').on('input', function(e) {
                const val = $(this).val();
                if (!/^[0-9]$/.test(val)) {
                    $(this).val('');
                    return;
                }
                const next = $(this).next('.otp-digit');
                if (next.length) {
                    next.prop('disabled', false).focus();
                }
            });

            $('.otp-digit').on('keydown', function(e) {
                if (e.key === 'Backspace') {
                    if ($(this).val() === '') {
                        const prev = $(this).prev('.otp-digit');
                        if (prev.length) {
                            $(this).prop('disabled', true);
                            prev.focus().val('');
                        }
                    } else {
                        $(this).val('');
                    }
                    e.preventDefault();
                }
            });

            // BƯỚC 1: Gọi API Forgot Password (Gửi mã OTP)
            $('#forgot-form').submit(function(e) {
                e.preventDefault();
                
                const email = $('#email').val().trim();
                const emailInput = $('#email')[0];
                const emailRegex = /^[^\s@@]+@@[^\s@@]+\.[^\s@@]+$/;

                if (!email) {
                    emailInput.setCustomValidity("Email không được để trống.");
                    emailInput.reportValidity();
                    return;
                } else if (!emailRegex.test(email)) {
                    emailInput.setCustomValidity("Email không đúng định dạng.");
                    emailInput.reportValidity();
                    return;
                }
                emailInput.setCustomValidity("");
                
                setBtnLoading('forgot-submit-btn', true);
                $('#email').prop('disabled', true);

                $.ajax({
                    url: `${apiBaseUrl}/api/Auth/forgot-password`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: email }),
                    success: function(response) {
                        setBtnLoading('forgot-submit-btn', false);
                        $('#email').prop('disabled', false);
                        resetEmail = email;
                        
                        showSuccess("Mã OTP khôi phục đã được gửi vào email của bạn!", function() {
                            // Chuyển sang Bước 2
                            $('#forgot-form').addClass('d-none');
                            $('#otp-form').removeClass('d-none');
                            $('#page-title').text('Xác thực OTP');
                            $('#page-subtitle').text('Xác minh danh tính để tiếp tục');
                            $('#target-email-text').text(email);
                            
                            startResendTimer(); // Bắt đầu đếm ngược 30s
                            
                            setTimeout(() => {
                                $('.otp-digit').first().focus();
                            }, 200);
                        });
                    },
                    error: function(xhr) {
                        setBtnLoading('forgot-submit-btn', false);
                        $('#email').prop('disabled', false);
                        let errorMsg = 'Kết nối tới máy chủ gặp lỗi.';
                        if (xhr.responseJSON) {
                            if (xhr.responseJSON.errors && xhr.responseJSON.errors.length > 0) {
                                errorMsg = xhr.responseJSON.errors.join('<br>');
                            } else if (xhr.responseJSON.message) {
                                errorMsg = xhr.responseJSON.message;
                            }
                        }
                        showError(errorMsg);
                    }
                });
            });

            // BƯỚC 2: Gọi API Verify OTP
            $('#otp-form').submit(function(e) {
                e.preventDefault();
                
                let otp = '';
                $('.otp-digit').each(function() {
                    otp += $(this).val();
                });

                if (otp.length < 6) {
                    showError("Vui lòng nhập đầy đủ mã OTP gồm 6 chữ số.");
                    return;
                }

                setBtnLoading('otp-submit-btn', true);
                $('.otp-digit').prop('disabled', true);

                $.ajax({
                    url: `${apiBaseUrl}/api/Auth/verify-reset-otp`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify({ email: resetEmail, otp: otp }),
                    success: function(response) {
                        setBtnLoading('otp-submit-btn', false);
                        verifiedOtp = otp; // Lưu lại OTP hợp lệ để dùng cho bước 3
                        
                        showSuccess("Xác thực thành công!", function() {
                            // Chuyển sang Bước 3
                            $('#otp-form').addClass('d-none');
                            $('#reset-form').removeClass('d-none');
                            $('#page-title').text('Đặt lại mật khẩu');
                            $('#page-subtitle').text('Tạo mật khẩu mới cho tài khoản của bạn');
                            
                            setTimeout(() => {
                                $('#new-password').focus();
                            }, 200);
                        });
                    },
                    error: function(xhr) {
                        setBtnLoading('otp-submit-btn', false);
                        // Bật lại các ô OTP để nhập lại
                        let otpFilled = false;
                        $('.otp-digit').each(function() {
                            if ($(this).val()) $(this).prop('disabled', false);
                            else if (!otpFilled) {
                                $(this).prop('disabled', false);
                                otpFilled = true;
                            }
                        });

                        let errorMsg = 'Mã OTP không hợp lệ.';
                        if (xhr.responseJSON) {
                            if (xhr.responseJSON.errors && xhr.responseJSON.errors.length > 0) {
                                errorMsg = xhr.responseJSON.errors.join('<br>');
                            } else if (xhr.responseJSON.message) {
                                errorMsg = xhr.responseJSON.message;
                            }
                        }
                        showError(errorMsg);
                    }
                });
            });

            // BƯỚC 3: Gọi API Reset Password (Mật khẩu mới)
            $('#reset-form').submit(function(e) {
                e.preventDefault();
                
                const newPassword = $('#new-password').val();
                const confirmPassword = $('#confirm-password').val();
                const newPassInput = $('#new-password')[0];
                const confirmPassInput = $('#confirm-password')[0];

                if (!newPassword || newPassword.length < 6) {
                    newPassInput.setCustomValidity("Mật khẩu mới phải có ít nhất 6 ký tự.");
                    newPassInput.reportValidity();
                    return;
                }
                newPassInput.setCustomValidity("");

                if (newPassword !== confirmPassword) {
                    confirmPassInput.setCustomValidity("Xác nhận mật khẩu không khớp.");
                    confirmPassInput.reportValidity();
                    return;
                }
                confirmPassInput.setCustomValidity("");

                setBtnLoading('reset-submit-btn', true);
                $('#new-password, #confirm-password').prop('disabled', true);

                const payload = {
                    email: resetEmail,
                    otp: verifiedOtp, // OTP đã pass ở bước 2
                    newPassword: newPassword,
                    confirmPassword: confirmPassword
                };

                $.ajax({
                    url: `${apiBaseUrl}/api/Auth/reset-password`,
                    type: 'POST',
                    contentType: 'application/json',
                    data: JSON.stringify(payload),
                    success: function(response) {
                        setBtnLoading('reset-submit-btn', false);
                        
                        Swal.fire({
                            icon: 'success',
                            title: 'Thành công!',
                            text: 'Mật khẩu của bạn đã được đặt lại thành công. Đang điều hướng đến trang Đăng nhập...',
                            confirmButtonColor: '#0284c7',
                            timer: 2500,
                            timerProgressBar: true,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.href = '/Auth/Login'; // Chuyển thẳng về trang Login
                        });
                    },
                    error: function(xhr) {
                        setBtnLoading('reset-submit-btn', false);
                        $('#new-password, #confirm-password').prop('disabled', false);

                        let errorMsg = 'Kết nối tới máy chủ gặp lỗi.';
                        if (xhr.responseJSON) {
                            if (xhr.responseJSON.errors && xhr.responseJSON.errors.length > 0) {
                                errorMsg = xhr.responseJSON.errors.join('<br>');
                            } else if (xhr.responseJSON.message) {
                                errorMsg = xhr.responseJSON.message;
                            }
                        }
                        showError(errorMsg);
                    }
                });
            });

            // Tự động clear lỗi custom khi nhập
            $('#email, #new-password, #confirm-password').on('input change', function() {
                this.setCustomValidity("");
            });
        });
    </script>
</body>
</html>
