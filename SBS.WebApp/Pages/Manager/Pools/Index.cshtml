@page
@model SBS.WebApp.Pages.Manager.Pools.IndexModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Quản lý Bể bơi";
    ViewData["Breadcrumb"] = "Quản lý / Bể bơi";
}

@section Styles {
    <link rel="stylesheet" href="~/css/manager-pools-index.css" asp-append-version="true" />
}

<!-- ── Page Header ───────────────────────────────── -->
<div class="mb-4">
    <div class="page-header-pill">
        <i class="fa-solid fa-water"></i> Quản lý Bể bơi
    </div>
    <h4 class="fw-bold text-dark mb-1 mt-1" style="font-size:22px;">Danh sách Bể bơi</h4>
    <p class="text-muted small mb-0">Theo dõi, cập nhật thông tin và trạng thái các bể bơi trong hệ thống.</p>
</div>

<!-- ── Filter Bar ────────────────────────────────── -->
<div class="filter-card">
    <div class="filter-search">
        <span class="search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
        <input type="text" id="searchInput" placeholder="Tìm tên bể bơi, địa chỉ...">
    </div>
    <select id="statusFilter" class="filter-select">
        <option value="">Tất cả trạng thái</option>
        <option value="Active">Đang hoạt động</option>
        <option value="Closed">Tạm đóng</option>
    </select>
    <div class="text-muted small" id="resultCount"></div>
    <a href="/Manager/Pools/Create" class="btn btn-primary fw-semibold shadow-sm px-4 ms-auto"
       style="border-radius:12px; padding-top:9px; padding-bottom:9px; white-space:nowrap; flex-shrink:0;">
        <i class="fa-solid fa-plus me-2"></i>Thêm bể bơi mới
    </a>
</div>

<!-- ── Table Card ────────────────────────────────── -->
<div class="pool-table-card">
    <div class="table-responsive">
        <table class="table mb-0">
            <thead>
                <tr>
                    <th style="padding-left:24px; width:35%;">Bể bơi</th>
                    <th style="width:30%;">Địa chỉ</th>
                    <th class="text-center" style="width:15%;">Giờ hoạt động</th>
                    <th class="text-center" style="width:10%;">Trạng thái</th>
                    <th class="text-center" style="padding-right:24px; width:10%;">Hành động</th>
                </tr>
            </thead>
            <tbody id="poolTableBody">
                <tr>
                    <td colspan="5" class="text-center py-5 text-muted">
                        <div class="spinner-border text-primary mb-2" style="width:2rem;height:2rem;"></div>
                        <div class="small">Đang tải dữ liệu...</div>
                    </td>
                </tr>
            </tbody>
        </table>
    </div>

    <!-- ── Pagination (centered) ─────────────────── -->
    <div class="pagination-wrapper">
        <div class="page-info-text" id="pageInfo">Hiển thị 0 - 0 trong 0 bể bơi</div>
        <ul class="custom-pagination" id="pagination"></ul>
    </div>
</div>

<!-- ── Confirm Modal ─────────────────────────────── -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg" style="border-radius:20px; overflow:hidden;">
            <div class="modal-body text-center p-5">
                <div class="mb-4" style="font-size:3rem;">⚠️</div>
                <h5 class="fw-bold mb-2" id="confirmTitle">Xác nhận</h5>
                <p class="text-muted mb-4 small" id="confirmMessage">Bạn có chắc chắn muốn thực hiện?</p>
                <div class="d-flex gap-2">
                    <button type="button" class="btn btn-light border flex-fill" data-bs-dismiss="modal"
                            style="border-radius:12px;">Hủy</button>
                    <button type="button" class="btn btn-danger flex-fill" id="btnConfirmAction"
                            style="border-radius:12px;">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        let confirmActionCb = null;
        let currentPage = 1;
        const pageSize = 5;

        $(document).ready(function () {
            loadPools(1);

            let timer = null;
            $('#searchInput').on('input', function () {
                clearTimeout(timer);
                timer = setTimeout(() => loadPools(1), 450);
            });
            $('#statusFilter').on('change', function () { loadPools(1); });
        });

        async function loadPools(page) {
            currentPage = page;
            const search = $('#searchInput').val();
            const status = $('#statusFilter').val();
            let url = `/pools?page=${page}&pageSize=${pageSize}`;
            if (search) url += `&search=${encodeURIComponent(search)}`;
            if (status) url += `&status=${status}`;

            $('#poolTableBody').html(`
                <tr><td colspan="5" class="text-center py-5 text-muted">
                    <div class="spinner-border text-primary mb-2" style="width:1.8rem;height:1.8rem;"></div>
                    <div class="small">Đang tải...</div>
                </td></tr>`);

            try {
                const res = await api.get(url);
                const items = res.items || [];
                renderTable(items);
                renderPagination(res.totalCount, res.page, res.pageSize);
                updateStats(res.totalCount, items);
            } catch (e) {
                $('#poolTableBody').html(`
                    <tr><td colspan="5" class="text-center py-5 text-danger">
                        <i class="fa-solid fa-circle-exclamation fa-2x mb-2"></i>
                        <div class="small">Lỗi tải dữ liệu. Vui lòng thử lại.</div>
                    </td></tr>`);
            }
        }

        function updateStats(total, items) {
            const activeCount = items.filter(p => p.status === 'Active').length;
            const closedCount = items.filter(p => p.status !== 'Active').length;
            $('#statTotal').text(total);
            $('#statActive').text(activeCount);
            $('#statClosed').text(closedCount);
            $('#statSlots').text(items.length);
            $('#resultCount').text(total > 0 ? `Tìm thấy ${total} kết quả` : '');
        }

        function renderPagination(totalCount, page, pSize) {
            const totalPages = Math.ceil(totalCount / pSize) || 1;
            const startItem = totalCount === 0 ? 0 : (page - 1) * pSize + 1;
            const endItem = Math.min(page * pSize, totalCount);

            $('#pageInfo').html(
                `Hiển thị <strong>${startItem} \u2013 ${endItem}</strong> trong <strong>${totalCount}</strong> bể bơi`
            );

            let html = '';
            html += `<li><a class="pg-btn ${page === 1 ? 'disabled' : ''}" href="#"
                onclick="if(${page}>1){loadPools(${page - 1});} return false;">
                <i class="fa-solid fa-chevron-left" style="font-size:11px;"></i></a></li>`;

            const delta = 2;
            let startPage = Math.max(1, page - delta);
            let endPage   = Math.min(totalPages, page + delta);

            if (startPage > 1) {
                html += `<li><a class="pg-btn" href="#" onclick="loadPools(1); return false;">1</a></li>`;
                if (startPage > 2) html += `<li><span class="pg-dots">\u00B7\u00B7\u00B7</span></li>`;
            }
            for (let i = startPage; i <= endPage; i++) {
                html += `<li><a class="pg-btn ${page === i ? 'active' : ''}" href="#"
                    onclick="loadPools(${i}); return false;">${i}</a></li>`;
            }
            if (endPage < totalPages) {
                if (endPage < totalPages - 1) html += `<li><span class="pg-dots">\u00B7\u00B7\u00B7</span></li>`;
                html += `<li><a class="pg-btn" href="#" onclick="loadPools(${totalPages}); return false;">${totalPages}</a></li>`;
            }

            html += `<li><a class="pg-btn ${page === totalPages ? 'disabled' : ''}" href="#"
                onclick="if(${page}<${totalPages}){loadPools(${page + 1});} return false;">
                <i class="fa-solid fa-chevron-right" style="font-size:11px;"></i></a></li>`;

            $('#pagination').html(html);
        }

        function renderTable(list) {
            if (list.length === 0) {
                $('#poolTableBody').html(`
                    <tr><td colspan="5" class="text-center py-5">
                        <i class="fa-solid fa-water fa-3x text-muted opacity-25 mb-3 d-block"></i>
                        <div class="fw-semibold text-muted">Không tìm thấy bể bơi nào</div>
                        <div class="small text-muted mt-1">Thử thay đổi từ khoá tìm kiếm hoặc bộ lọc</div>
                    </td></tr>`);
                return;
            }

            let html = '';
            list.forEach(p => {
                const isClosed = p.status !== 'Active';
                const coverImg = p.images && p.images.length > 0
                    ? (p.images.find(i => i.isCover)?.imageUrl || p.images[0].imageUrl)
                    : 'https://placehold.co/60x60/e0f2fe/0284c7?text=Pool';

                const overlay = isClosed
                    ? `<div class="pool-avatar-overlay"><i class="fa-solid fa-lock"></i></div>` : '';

                const statusBadge = isClosed
                    ? `<span class="status-badge closed"><span class="status-dot closed"></span>Tạm đóng</span>`
                    : `<span class="status-badge active"><span class="status-dot active"></span>Hoạt động</span>`;

                const lockBtn = isClosed
                    ? `<button class="action-btn unlock" onclick="reopenPool(${p.poolId})" title="Mở lại bể bơi">
                            <i class="fa-solid fa-lock-open"></i></button>`
                    : `<button class="action-btn open" onclick="confirmClose(${p.poolId}, '${p.poolName.replace(/'/g, "\\'")}')" title="Đóng tạm thời">
                            <i class="fa-solid fa-lock"></i></button>`;

                html += `
                <tr>
                    <td style="padding:14px 16px 14px 24px;">
                        <div class="d-flex align-items-center gap-3">
                            <div class="position-relative" style="flex-shrink:0;">
                                <img src="${coverImg}" alt="${p.poolName}" class="pool-avatar">
                                ${overlay}
                            </div>
                            <div style="min-width:0;">
                                <div class="fw-semibold text-dark" style="font-size:14px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:220px;">${p.poolName}</div>
                                <div class="text-muted mt-1" style="font-size:12px;">
                                    <i class="fa-solid fa-ruler-combined text-primary me-1"></i>${p.area ? p.area + ' m²' : 'Chưa có diện tích'}
                                </div>
                            </div>
                        </div>
                    </td>
                    <td style="padding:14px 16px;">
                        <div class="d-flex align-items-start gap-2 text-muted" style="font-size:13px;max-width:260px;">
                            <i class="fa-solid fa-location-dot text-danger mt-1" style="flex-shrink:0;"></i>
                            <span style="display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">${p.address}</span>
                        </div>
                    </td>
                    <td class="text-center" style="padding:14px 16px;">
                        <span class="time-badge">
                            <i class="fa-regular fa-clock"></i>
                            ${p.openingTime.substring(0,5)} \u2013 ${p.closingTime.substring(0,5)}
                        </span>
                    </td>
                    <td class="text-center" style="padding:14px 16px;">
                        ${statusBadge}
                    </td>
                    <td class="text-center" style="padding:14px 24px 14px 16px;">
                        <div class="d-flex justify-content-center align-items-center gap-2">
                            ${lockBtn}
                            <a href="/Manager/Pools/Edit/${p.poolId}" class="action-btn edit" title="Chỉnh sửa">
                                <i class="fa-solid fa-pen"></i>
                            </a>
                        </div>
                    </td>
                </tr>`;
            });
            $('#poolTableBody').html(html);
        }

        function confirmClose(id, name) {
            $('#confirmTitle').text('Đóng bể bơi?');
            $('#confirmMessage').text(`Bể bơi "${name}" sẽ không nhận booking mới. Bạn có chắc chắn?`);
            confirmActionCb = async () => {
                try {
                    await api.patch(`/pools/${id}/close`);
                    toastr.success('Đã đóng bể bơi thành công.');
                    confirmModal.hide();
                    loadPools(currentPage);
                } catch (e) {}
            };
            confirmModal.show();
        }

        async function reopenPool(id) {
            try {
                await api.patch(`/pools/${id}/reopen`);
                toastr.success('Đã mở lại bể bơi thành công.');
                loadPools(currentPage);
            } catch (e) {}
        }

        $('#btnConfirmAction').on('click', function () {
            if (confirmActionCb) confirmActionCb();
        });
    </script>
}
