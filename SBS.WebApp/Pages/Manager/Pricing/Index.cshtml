@page
@model SBS.WebApp.Pages.Manager.Pricing.IndexModel
@{
    Layout = "_ManagerLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/manager-pricing.css" asp-append-version="true" />
}

<!-- Page Header -->
<div class="pricing-header">
    <h4><i class="fa-solid fa-tags me-2 text-primary"></i>Bảng giá theo Bể bơi</h4>
</div>

<!-- Pool Tab Bar -->
<div class="pool-tab-bar" id="poolTabBar">
    <div class="text-muted small p-2"><i class="fa-solid fa-spinner fa-spin me-1"></i> Đang tải bể bơi...</div>
</div>

<!-- Pool Info Banner -->
<div class="pool-info-banner" id="poolInfoBanner" style="display: none;">
    <img class="pool-avatar" id="bannerAvatar" src="https://placehold.co/56x56?text=?" alt="">
    <div class="pool-details">
        <h5 id="bannerPoolName">—</h5>
        <p id="bannerPoolInfo">—</p>
    </div>
    <div class="ms-auto d-flex gap-2">
        <button class="btn btn-sm btn-outline-primary" onclick="refreshPricing()">
            <i class="fa-solid fa-rotate me-1"></i> Làm mới
        </button>
    </div>
</div>

<!-- Pricing Table -->
<div class="pricing-table-wrapper" id="pricingTableWrapper">
    <table class="pricing-table">
        <thead>
            <tr>
                <th>Loại vé</th>
                <th>Mã</th>
                <th>Loại</th>
                <th>Giá gốc (Base)</th>
                <th>Giá tại bể bơi</th>
                <th>Chênh lệch</th>
                <th>Trạng thái</th>
                <th style="width: 160px; text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody id="pricingTableBody">
            <tr>
                <td colspan="8">
                    <div class="pricing-empty">
                        <i class="fa-solid fa-hand-pointer"></i>
                        <p>Chọn một bể bơi ở trên để xem bảng giá.</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    <div class="pricing-summary" id="pricingSummary" style="display: none;">
        <span id="summaryText"></span>
    </div>
</div>

<!-- Edit Price Modal -->
<div class="modal fade" id="priceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content price-edit-modal">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa-solid fa-pen me-2"></i>Cập nhật giá vé</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editPoolId">
                <input type="hidden" id="editTicketTypeId">

                <div class="current-info">
                    <div class="row">
                        <div class="col-6">
                            <label>Loại vé</label>
                            <div class="value" id="priceModalTicketName">—</div>
                        </div>
                        <div class="col-6">
                            <label>Giá gốc (Base)</label>
                            <div class="value" id="priceModalBasePrice">—</div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Giá mới tại bể bơi (VNĐ) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control form-control-lg" id="newPrice" min="0" step="1000" placeholder="Nhập giá mới">
                    <div class="form-text">Để giá 0 hoặc bằng giá gốc nếu không muốn áp giá riêng.</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-4" onclick="savePrice()">
                    <i class="fa-solid fa-save me-1"></i> Lưu giá
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fa-solid fa-triangle-exclamation text-warning mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3" id="confirmTitle">Xác nhận</h5>
                <p class="text-muted mb-4" id="confirmMessage"></p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light border w-50" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger w-50" id="btnConfirmAction">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let pools = [];
        let poolTickets = [];
        let selectedPoolId = null;
        let priceModal, confirmModal, confirmCb;

        $(document).ready(function () {
            priceModal = new bootstrap.Modal(document.getElementById('priceModal'));
            confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
            loadPools();
        });

        // ── LOAD POOLS ───────────────────────────────────────────────
        async function loadPools() {
            try {
                const res = await api.get('/pools?pageSize=100');
                pools = res.items || [];
                renderPoolTabs();
                if (pools.length > 0) {
                    selectPool(pools[0].poolId);
                }
            } catch (e) { }
        }

        function renderPoolTabs() {
            if (pools.length === 0) {
                $('#poolTabBar').html('<p class="text-muted small p-3 mb-0">Chưa có bể bơi nào. Vui lòng tạo bể bơi trước.</p>');
                return;
            }
            let html = '';
            pools.forEach(p => {
                html += `<button class="pool-tab" data-pool-id="${p.poolId}" onclick="selectPool(${p.poolId})">
                    <i class="fa-solid fa-water"></i> ${p.poolName}
                </button>`;
            });
            $('#poolTabBar').html(html);
        }

        async function selectPool(poolId) {
            selectedPoolId = poolId;
            // Update tab active state
            $('.pool-tab').removeClass('active');
            $(`.pool-tab[data-pool-id="${poolId}"]`).addClass('active');

            // Update banner
            const pool = pools.find(p => p.poolId === poolId);
            if (pool) {
                const coverImg = pool.images && pool.images.length > 0
                    ? (pool.images.find(i => i.isCover)?.imageUrl || pool.images[0].imageUrl)
                    : 'https://placehold.co/56x56?text=' + encodeURIComponent(pool.poolName.charAt(0));
                $('#bannerAvatar').attr('src', coverImg);
                $('#bannerPoolName').text(pool.poolName);
                $('#bannerPoolInfo').html(`<i class="fa-solid fa-location-dot me-1"></i>${pool.address} &nbsp;|&nbsp; <i class="fa-regular fa-clock me-1"></i>${pool.openingTime} - ${pool.closingTime}`);
                $('#poolInfoBanner').show();
            }

            await loadPoolTickets(poolId);
        }

        // ── LOAD POOL TICKETS ────────────────────────────────────────
        async function loadPoolTickets(poolId) {
            try {
                poolTickets = await api.get(`/pools/${poolId}/ticket-types`);
                renderPricingTable(poolTickets);
            } catch (e) {
                renderPricingTable([]);
            }
        }

        function refreshPricing() {
            if (selectedPoolId) loadPoolTickets(selectedPoolId);
        }

        // ── RENDER TABLE ─────────────────────────────────────────────
        function renderPricingTable(list) {
            if (!list || list.length === 0) {
                $('#pricingTableBody').html(`
                    <tr><td colspan="8">
                        <div class="pricing-empty">
                            <i class="fa-solid fa-tags"></i>
                            <p>Bể bơi này chưa có loại vé nào được gán.<br>
                            <span class="small">Hãy vào trang <a href="/Manager/Tickets" class="text-primary fw-semibold">Quản lý Loại vé</a> để tạo vé và áp dụng cho bể bơi này.</span></p>
                        </div>
                    </td></tr>`);
                $('#pricingSummary').hide();
                return;
            }

            let html = '';
            list.forEach(t => {
                const isActive = t.status === 'Active';
                const isCombo = t.category === 'Combo';
                const diff = t.price - t.basePrice;
                let diffHtml = '';
                if (diff > 0) {
                    diffHtml = `<span class="price-diff up"><i class="fa-solid fa-arrow-up"></i> +${formatMoney(diff)}</span>`;
                } else if (diff < 0) {
                    diffHtml = `<span class="price-diff down"><i class="fa-solid fa-arrow-down"></i> ${formatMoney(diff)}</span>`;
                } else {
                    diffHtml = `<span class="price-diff same">Bằng giá gốc</span>`;
                }

                html += `
                <tr>
                    <td>
                        <div class="ticket-info-cell">
                            <div class="ticket-icon ${isCombo ? 'combo' : 'single'}">
                                <i class="fa-solid ${isCombo ? 'fa-cubes' : 'fa-ticket'}"></i>
                            </div>
                            <div>
                                <div class="ticket-name">${t.ticketName}</div>
                                <div class="ticket-code">${t.ticketCode}</div>
                            </div>
                        </div>
                    </td>
                    <td><span style="font-family: monospace; color: #0284c7; font-weight: 600;">${t.ticketCode}</span></td>
                    <td>
                        <span class="category-badge ${isCombo ? 'combo' : 'single'}">
                            <i class="fa-solid ${isCombo ? 'fa-cubes' : 'fa-ticket'}"></i> ${t.category}
                        </span>
                    </td>
                    <td><span class="price-base">${formatMoney(t.basePrice)}</span></td>
                    <td><span class="price-current">${formatMoney(t.price)}</span></td>
                    <td>${diffHtml}</td>
                    <td><span class="pricing-status ${isActive ? 'active' : 'closed'}">${isActive ? 'Hoạt động' : 'Đã đóng'}</span></td>
                    <td>
                        <div class="d-flex gap-1 justify-content-center">
                            <button class="pricing-action-btn" title="Sửa giá" onclick="openPriceModal(${t.ticketTypeId})">
                                <i class="fa-solid fa-pen"></i>
                            </button>
                            ${isActive
                    ? `<button class="pricing-action-btn" title="Đóng vé tại bể này" onclick="togglePoolTicket(${t.ticketTypeId}, 'close')" style="color:#ef4444;"><i class="fa-solid fa-ban"></i></button>`
                    : `<button class="pricing-action-btn" title="Mở lại" onclick="togglePoolTicket(${t.ticketTypeId}, 'open')"><i class="fa-solid fa-rotate-left"></i></button>`
                }
                        </div>
                    </td>
                </tr>`;
            });
            $('#pricingTableBody').html(html);

            // Summary
            const activeCount = list.filter(t => t.status === 'Active').length;
            $('#summaryText').text(`Tổng: ${list.length} loại vé | ${activeCount} đang hoạt động`);
            $('#pricingSummary').show();
        }

        // ── EDIT PRICE ───────────────────────────────────────────────
        function openPriceModal(ticketTypeId) {
            const t = poolTickets.find(x => x.ticketTypeId === ticketTypeId);
            if (!t) return;
            $('#editPoolId').val(selectedPoolId);
            $('#editTicketTypeId').val(ticketTypeId);
            $('#priceModalTicketName').text(`${t.ticketCode} — ${t.ticketName}`);
            $('#priceModalBasePrice').text(formatMoney(t.basePrice));
            $('#newPrice').val(t.price);
            priceModal.show();
        }

        async function savePrice() {
            const poolId = parseInt($('#editPoolId').val());
            const ticketTypeId = parseInt($('#editTicketTypeId').val());
            const price = parseFloat($('#newPrice').val());

            if (isNaN(price) || price < 0) {
                toastr.warning('Vui lòng nhập giá hợp lệ.');
                return;
            }

            try {
                await api.patch(`/pools/${poolId}/ticket-types/${ticketTypeId}/price`, { price: price });
                toastr.success('Cập nhật giá thành công!');
                priceModal.hide();
                loadPoolTickets(poolId);
            } catch (e) { }
        }

        // ── TOGGLE STATUS ────────────────────────────────────────────
        function togglePoolTicket(ticketTypeId, action) {
            const t = poolTickets.find(x => x.ticketTypeId === ticketTypeId);
            const label = action === 'close' ? 'đóng' : 'mở lại';
            $('#confirmTitle').text(`Xác nhận ${label} vé?`);
            $('#confirmMessage').text(`Bạn có chắc muốn ${label} vé "${t?.ticketName}" tại bể bơi này?`);
            confirmCb = async () => {
                try {
                    await api.patch(`/pools/${selectedPoolId}/ticket-types/${ticketTypeId}/${action}`);
                    toastr.success(`Đã ${label} vé thành công.`);
                    confirmModal.hide();
                    loadPoolTickets(selectedPoolId);
                } catch (e) { }
            };
            confirmModal.show();
        }

        $('#btnConfirmAction').click(function () { if (confirmCb) confirmCb(); });

        // ── UTILS ────────────────────────────────────────────────────
        function formatMoney(v) {
            return new Intl.NumberFormat('vi-VN').format(Math.round(v)) + ' ₫';
        }
    </script>
}
