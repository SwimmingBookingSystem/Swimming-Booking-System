@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Staff Portal</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Toastr for Notifications -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- Staff Custom CSS -->
    <link rel="stylesheet" href="~/css/staff.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav id="sidebar">
        <div class="sidebar-header position-relative">
            <div>
                <a href="/Staff/CheckIn" class="brand">
                    <i class="fa-solid fa-water text-info me-2"></i> SBS Staff
                </a>
                <div id="userPoolDisplay" class="text-info small mt-1" style="display: none; font-size: 0.85rem;">
                    <i class="fa-solid fa-location-dot me-1"></i> <span class="pool-name-text"></span>
                </div>
            </div>
            <button type="button" id="sidebarClose" class="btn btn-link text-white d-md-none p-0 border-0 position-absolute top-0 end-0 mt-3 me-3">
                <i class="fa-solid fa-xmark fs-4"></i>
            </button>
        </div>
        <div class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Staff/CheckIn" ? "active" : "")" href="/Staff/CheckIn">
                <i class="fa-solid fa-qrcode w-20px"></i> Check-in / Out
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString()?.StartsWith("/Staff/Bookings") == true ? "active" : "")" href="/Staff/Bookings">
                <i class="fa-solid fa-ticket w-20px"></i> Quản lý Booking
            </a>
            <hr class="my-2" style="border-color: rgba(255,255,255,0.1);">
            <a class="nav-link text-white-50" href="/" style="font-size: 0.85rem;">
                <i class="fa-solid fa-arrow-left w-20px"></i> Về trang chủ
            </a>
        </div>
    </nav>

    <!-- Main Content -->
    <div id="content">
        <!-- Topbar -->
        <div class="topbar">
            <div class="d-flex align-items-center">
                <button type="button" id="sidebarCollapse" class="btn btn-light border-0 shadow-sm rounded-circle me-3 d-md-none" style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="breadcrumb mb-0 fw-medium text-muted">
                    @ViewData["Breadcrumb"]
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                @{
                    var staffFullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Staff";
                    var staffPoolName = User.FindFirst("PoolName")?.Value ?? "";
                    var staffAvatarUrl = User.FindFirst("AvatarUrl")?.Value;
                    var defaultStaffAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(staffFullName)}&background=0284C7&color=fff";
                    var staffAvatarSrc = !string.IsNullOrEmpty(staffAvatarUrl) ? staffAvatarUrl : defaultStaffAvatar;
                    
                    // Kiểm tra quyền Staff/Manager/Admin từ Server-side
                    if (User.Identity == null || !User.Identity.IsAuthenticated || 
                        (!User.IsInRole("Staff") && !User.IsInRole("Manager") && !User.IsInRole("Admin")))
                    {
                        Context.Response.Redirect("/Auth/Login");
                    }
                }
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle rounded-pill border-0 shadow-sm px-3 py-2" type="button" data-bs-toggle="dropdown" id="userMenuBtn">
                        <img id="userAvatar" src="@staffAvatarSrc" class="rounded-circle me-2" width="32" height="32" style="object-fit: cover;" />
                        <span id="userNameDisplay" class="fw-medium">@staffFullName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                        <li><a class="dropdown-item text-danger py-2" href="/Auth/Logout"><i class="fa-solid fa-right-from-bracket me-2"></i>&#x0110;&#x0103;ng xu&#x1EA5;t</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <!-- Sidebar Overlay for mobile -->
    <div id="sidebar-overlay" class="d-none"></div>

    <!-- Global Loader -->
    <div id="global-loader">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <!-- HTML5 QR Code Library for Camera Scanning -->
    <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

    <script>
        // Lấy token được giải mã ở server và nhúng vào biến JS
        // Cookie gốc đã được trình duyệt ẩn đi và mã hóa qua .AspNetCore.Cookies (HttpOnly)
        window.ACCESS_TOKEN = '@(User.FindFirst("AccessToken")?.Value ?? "")';
        window.API_BASE_URL = '@Configuration["ApiBaseUrl"]';

        $(document).ready(function() {
            var poolName = '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(staffPoolName))';
            if (poolName) {
                $('#userPoolDisplay .pool-name-text').text(poolName);
                $('#userPoolDisplay').show();
            }

            // Sidebar toggles for mobile responsiveness
            $('#sidebarCollapse, #sidebarClose, #sidebar-overlay').on('click', function() {
                $('#sidebar').toggleClass('active');
                $('#sidebar-overlay').toggleClass('d-none');
            });
        });
    </script>
    <script>
        toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "3000" };
        window.API_BASE_URL = '@Configuration["ApiBaseUrl"]';

        const staffApi = {
            baseURL: window.API_BASE_URL + '/api/staff',
            request: function(method, url, data) {
                return new Promise((resolve, reject) => {
                    $('#global-loader').css('display', 'flex');
                    
                    const token = window.ACCESS_TOKEN;
                    if (!token) {
                        $('#global-loader').hide();
                        window.location.href = '/Auth/Logout';
                        reject(new Error("No active session available"));
                        return;
                    }

                    const headers = { 
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    };
                    
                    $.ajax({
                        url: this.baseURL + url, 
                        type: method, 
                        headers: headers,
                        xhrFields: { withCredentials: true },
                        data: data ? JSON.stringify(data) : null,
                        success: function(response) { 
                            $('#global-loader').hide(); 
                            resolve(response); 
                        },
                        error: function(xhr) {
                            $('#global-loader').hide();
                            console.error("Staff API Error: ", xhr);
                            const status = xhr.status;
                            let dataObj = {};
                            try { dataObj = JSON.parse(xhr.responseText); } catch(e) {}
                            
                            if (status === 401) {
                                toastr.error('Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.');
                                setTimeout(() => window.location.href = '/Auth/Logout', 1500);
                            } else if (status === 403) {
                                toastr.error('Bạn không có quyền thực hiện thao tác này tại hồ bơi.');
                            } else if (status === 400 || status === 404 || status === 422) {
                                const errs = dataObj.errors || dataObj.Errors;
                                const msg = dataObj.message || dataObj.Message;
                                const title = dataObj.title || dataObj.Title;
                                
                                if (errs && Array.isArray(errs) && errs.length > 0) {
                                    errs.forEach(err => toastr.error(err));
                                } else if (errs && typeof errs === 'object') {
                                    Object.values(errs).forEach(errArr => {
                                        if (Array.isArray(errArr)) errArr.forEach(err => toastr.error(err));
                                        else toastr.error(errArr); 
                                    });
                                } else if (msg) {
                                    toastr.error(msg);
                                } else if (title) {
                                    toastr.error(title);
                                } else {
                                    toastr.error('Lỗi (' + status + '): ' + (xhr.responseText ? xhr.responseText.substring(0,100) : 'Yêu cầu không hợp lệ.'));
                                }
                            } else if (status === 500) {
                                toastr.error('Đã xảy ra lỗi hệ thống (500). Vui lòng thử lại sau.');
                            } else {
                                toastr.error('Lỗi máy chủ không xác định.');
                            }
                            reject(xhr);
                        }
                    });
                });
            },
            get: function(url) { return this.request('GET', url); },
            post: function(url, data) { return this.request('POST', url, data); },
            put: function(url, data) { return this.request('PUT', url, data); },
            patch: function(url, data) { return this.request('PATCH', url, data); },
            delete: function(url) { return this.request('DELETE', url); }
        };
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
