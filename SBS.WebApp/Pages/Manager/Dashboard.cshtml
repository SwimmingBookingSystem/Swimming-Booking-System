@page
@model SBS.WebApp.Pages.Manager.DashboardModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Tổng quan";
}

<style>
    /* Dashboard Specific Styles */
    .dashboard-header {
        margin-bottom: 24px;
    }
    .kpi-card {
        border: none;
        border-radius: 16px;
        transition: transform 0.2s, box-shadow 0.2s;
        overflow: hidden;
        position: relative;
    }
    .kpi-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.05) !important;
    }
    .kpi-icon-wrap {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.25rem;
    }
    .kpi-value {
        font-size: 1.8rem;
        font-weight: 800;
        letter-spacing: -0.5px;
        color: #0f172a;
    }
    .kpi-label {
        font-size: 0.85rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .card-modern {
        border: none;
        border-radius: 16px;
        box-shadow: 0 4px 6px -1px rgba(0,0,0,0.02);
    }
    .card-modern-header {
        background: transparent;
        border-bottom: 1px solid #f1f5f9;
        padding: 20px 24px;
        font-weight: 700;
        color: #0f172a;
        font-size: 1.1rem;
    }
    .quick-action-btn {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 16px;
        border-radius: 12px;
        border: 1px solid #e2e8f0;
        color: #334155;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.2s;
    }
    .quick-action-btn:hover {
        background: #f8fafc;
        border-color: #cbd5e1;
        color: #0ea5e9;
    }
    .quick-action-icon {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .chart-container {
        position: relative;
        height: 300px;
        width: 100%;
    }
</style>

<!-- Welcome Header -->
<div class="dashboard-header d-flex justify-content-between align-items-end">
    <div>
        <h3 class="fw-bold text-dark mb-1">Tổng quan hệ thống</h3>
        <p class="text-muted mb-0" id="currentDateText"><i class="fa-regular fa-calendar me-1"></i> Đang tải ngày...</p>
    </div>
    <div>
        <a href="/Manager/Pools/Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fa-solid fa-plus me-2"></i>Thêm Bể bơi
        </a>
    </div>
</div>

<!-- KPI Cards -->
<div class="row g-4 mb-4">
    <!-- Total Pools -->
    <div class="col-md-6 col-xl-3">
        <div class="card kpi-card shadow-sm h-100">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-icon-wrap bg-primary bg-opacity-10 text-primary">
                        <i class="fa-solid fa-swimming-pool"></i>
                    </div>
                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill px-2 py-1">+12% tháng này</span>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-total-pools">--</div>
                    <div class="kpi-label mt-1">Tổng số Cơ sở / Bể bơi</div>
                </div>
            </div>
            <div class="position-absolute bottom-0 end-0 p-3 opacity-10">
                <i class="fa-solid fa-building-circle-check" style="font-size: 4rem;"></i>
            </div>
        </div>
    </div>
    
    <!-- Active Pools -->
    <div class="col-md-6 col-xl-3">
        <div class="card kpi-card shadow-sm h-100">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-icon-wrap bg-success bg-opacity-10 text-success">
                        <i class="fa-solid fa-water"></i>
                    </div>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-active-pools">--</div>
                    <div class="kpi-label mt-1">Bể bơi đang hoạt động</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Active Tickets -->
    <div class="col-md-6 col-xl-3">
        <div class="card kpi-card shadow-sm h-100">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-icon-wrap bg-info bg-opacity-10 text-info">
                        <i class="fa-solid fa-ticket"></i>
                    </div>
                </div>
                <div>
                    <div class="kpi-value" id="kpi-active-tickets">--</div>
                    <div class="kpi-label mt-1">Gói vé đang mở bán</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Revenue / System Status -->
    <div class="col-md-6 col-xl-3">
        <div class="card kpi-card shadow-sm h-100" style="background: linear-gradient(135deg, #0ea5e9 0%, #0284c7 100%); color: white;">
            <div class="card-body p-4 d-flex flex-column justify-content-between">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div class="kpi-icon-wrap bg-white bg-opacity-25 text-white">
                        <i class="fa-solid fa-wallet"></i>
                    </div>
                    <span class="badge bg-white bg-opacity-25 text-white rounded-pill px-2 py-1"><i class="fa-solid fa-arrow-trend-up me-1"></i>+8.5%</span>
                </div>
                <div>
                    <div class="kpi-value text-white" id="kpi-revenue">45.2M ₫</div>
                    <div class="kpi-label mt-1 text-white opacity-75" id="kpi-revenue-label">Doanh thu tuần này (Dự kiến)</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Charts Section -->
<div class="row g-4 mb-4">
    <!-- Revenue Chart -->
    <div class="col-lg-8">
        <div class="card card-modern h-100 shadow-sm">
            <div class="card-modern-header d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-chart-line me-2 text-primary"></i><span id="revenueChartTitle">Biểu đồ Doanh thu (7 ngày qua)</span></span>
                <div class="dropdown">
                    <button class="btn btn-sm btn-light border dropdown-toggle text-muted" type="button" data-bs-toggle="dropdown" id="timeRangeBtn">
                        Tuần này
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item" href="#" onclick="changeTimeRange('week', 'Tuần này', '7 ngày qua'); return false;">Tuần này</a></li>
                        <li><a class="dropdown-item" href="#" onclick="changeTimeRange('month', 'Tháng này', 'Tháng này'); return false;">Tháng này</a></li>
                        <li><a class="dropdown-item" href="#" onclick="changeTimeRange('year', 'Năm nay', 'Năm nay'); return false;">Năm nay</a></li>
                    </ul>
                </div>
            </div>
            <div class="card-body p-4">
                <div class="chart-container">
                    <canvas id="revenueChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Ticket Type Distribution -->
    <div class="col-lg-4">
        <div class="card card-modern h-100 shadow-sm">
            <div class="card-modern-header">
                <i class="fa-solid fa-chart-pie me-2 text-info"></i>Tỷ lệ vé bán ra
            </div>
            <div class="card-body p-4 d-flex align-items-center justify-content-center">
                <div style="height: 250px; width: 100%;">
                    <canvas id="ticketTypeChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Main Table Area -->
    <div class="col-lg-8">
        <div class="card card-modern h-100 shadow-sm">
            <div class="card-modern-header d-flex justify-content-between align-items-center">
                <span><i class="fa-solid fa-list me-2 text-primary"></i>Danh sách Bể bơi mới cập nhật</span>
                <a href="/Manager/Pools" class="btn btn-sm btn-light border text-muted">Xem tất cả</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-muted" style="font-size: 0.8rem; text-transform: uppercase;">
                            <tr>
                                <th class="ps-4 py-3 border-0 rounded-start">Tên bể bơi</th>
                                <th class="py-3 border-0">Địa chỉ</th>
                                <th class="py-3 border-0 text-center">Trạng thái</th>
                                <th class="pe-4 py-3 border-0 rounded-end text-end">Giờ hoạt động</th>
                            </tr>
                        </thead>
                        <tbody id="recent-pools-body">
                            <tr><td colspan="4" class="text-center text-muted p-5"><i class="fa-solid fa-spinner fa-spin fa-2x mb-3"></i><br>Đang tải dữ liệu...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Column: Quick Actions & Help -->
    <div class="col-lg-4">
        <div class="card card-modern shadow-sm mb-4">
            <div class="card-modern-header">
                <i class="fa-solid fa-bolt me-2 text-warning"></i>Thao tác nhanh
            </div>
            <div class="card-body p-4 d-flex flex-column gap-3">
                <a href="/Manager/Slots" class="quick-action-btn">
                    <div class="quick-action-icon bg-indigo bg-opacity-10 text-indigo" style="color: #6366f1; background: #e0e7ff;">
                        <i class="fa-regular fa-calendar-plus"></i>
                    </div>
                    <div>
                        <div class="mb-0">Tạo lịch / Ca bơi</div>
                        <small class="text-muted fw-normal">Thiết lập giờ mở bán tự động</small>
                    </div>
                    <i class="fa-solid fa-chevron-right ms-auto text-muted small"></i>
                </a>
                
                <a href="/Manager/Pricing" class="quick-action-btn">
                    <div class="quick-action-icon bg-rose bg-opacity-10 text-rose" style="color: #e11d48; background: #ffe4e6;">
                        <i class="fa-solid fa-tags"></i>
                    </div>
                    <div>
                        <div class="mb-0">Tùy chỉnh giá vé</div>
                        <small class="text-muted fw-normal">Ghi đè giá vé tại từng cơ sở</small>
                    </div>
                    <i class="fa-solid fa-chevron-right ms-auto text-muted small"></i>
                </a>

                <a href="/Manager/Tickets/Create" class="quick-action-btn">
                    <div class="quick-action-icon bg-emerald bg-opacity-10 text-emerald" style="color: #10b981; background: #d1fae5;">
                        <i class="fa-solid fa-ticket"></i>
                    </div>
                    <div>
                        <div class="mb-0">Tạo loại vé mới</div>
                        <small class="text-muted fw-normal">Thêm vé đơn, vé tháng, vé combo</small>
                    </div>
                    <i class="fa-solid fa-chevron-right ms-auto text-muted small"></i>
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Import Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <script>
        let revenueChartInstance = null;
        let ticketChartInstance = null;

        $(document).ready(function() {
            // Set current date
            const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
            const todayStr = new Date().toLocaleDateString('vi-VN', options);
            $('#currentDateText').html(`<i class="fa-regular fa-calendar me-1"></i> Hôm nay: ${todayStr}`);

            loadDashboardData('week');
        });

        async function changeTimeRange(range, btnText, titleText) {
            $('#timeRangeBtn').text(btnText);
            $('#revenueChartTitle').text(`Biểu đồ Doanh thu (${titleText})`);
            
            let kpiText = range === 'week' ? 'Doanh thu 7 ngày qua' : (range === 'month' ? 'Doanh thu tháng này' : 'Doanh thu năm nay');
            $('#kpi-revenue-label').text(kpiText);
            
            await loadDashboardData(range);
        }

        async function loadDashboardData(timeRange = 'week') {
            try {
                // 1. Fetch real stats from our new backend API
                const stats = await api.get(`/dashboard/stats?timeRange=${timeRange}`);
                
                // 2. Update KPI Cards
                $('#kpi-total-pools').text(stats.totalPools);
                $('#kpi-active-pools').text(stats.activePools);
                $('#kpi-active-tickets').text(stats.activeTickets);
                
                // Format revenue to Triệu VNĐ (Millions)
                const revenueInMillions = (stats.periodRevenue / 1000000).toFixed(1);
                $('#kpi-revenue').text(revenueInMillions + 'M ₫');
                
                // Initialize Charts with REAL DATA
                initCharts(stats);

                // 3. Render recent pools (using existing API)
                const poolsRes = await api.get('/pools?pageSize=10');
                const pools = poolsRes.items || [];
                let html = '';
                if(pools.length === 0) {
                    html = '<tr><td colspan="4" class="text-center text-muted p-5">Chưa có cơ sở bể bơi nào trong hệ thống.</td></tr>';
                } else {
                    pools.slice(0, 5).forEach(p => {
                        let statusBadge = p.status === 'Active' 
                            ? '<span class="badge bg-success bg-opacity-10 text-success px-3 py-1 rounded-pill" style="font-weight: 600;"><i class="fa-solid fa-circle me-1" style="font-size: 0.4rem; vertical-align: middle;"></i>Hoạt động</span>'
                            : '<span class="badge bg-danger bg-opacity-10 text-danger px-3 py-1 rounded-pill" style="font-weight: 600;"><i class="fa-solid fa-circle me-1" style="font-size: 0.4rem; vertical-align: middle;"></i>Đã đóng</span>';
                            
                        html += `
                            <tr>
                                <td class="ps-4 py-3 fw-bold text-dark">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-primary bg-opacity-10 text-primary rounded d-flex align-items-center justify-content-center" style="width: 36px; height: 36px;">
                                            <i class="fa-solid fa-water"></i>
                                        </div>
                                        ${p.poolName}
                                    </div>
                                </td>
                                <td class="text-muted small py-3"><i class="fa-solid fa-location-dot me-1 text-primary opacity-50"></i> ${p.address}</td>
                                <td class="text-center py-3">${statusBadge}</td>
                                <td class="pe-4 py-3 text-end fw-medium text-dark">${p.openingTime.substring(0,5)} - ${p.closingTime.substring(0,5)}</td>
                            </tr>
                        `;
                    });
                }
                $('#recent-pools-body').html(html);

            } catch (error) {
                $('#recent-pools-body').html('<tr><td colspan="4" class="text-center text-danger p-5"><i class="fa-solid fa-triangle-exclamation mb-2 fa-2x"></i><br>Lỗi tải dữ liệu. Vui lòng thử lại sau.</td></tr>');
            }
        }

        function initCharts(stats) {
            // Destroy existing charts to prevent hover glitch/memory leak
            if (revenueChartInstance) {
                revenueChartInstance.destroy();
            }
            if (ticketChartInstance) {
                ticketChartInstance.destroy();
            }

            // Biểu đồ Line (Doanh thu thực tế)
            const ctxRev = document.getElementById('revenueChart').getContext('2d');
            
            let gradient = ctxRev.createLinearGradient(0, 0, 0, 300);
            gradient.addColorStop(0, 'rgba(14, 165, 233, 0.4)');
            gradient.addColorStop(1, 'rgba(14, 165, 233, 0.0)');

            revenueChartInstance = new Chart(ctxRev, {
                type: 'line',
                data: {
                    labels: stats.chartLabels, // Ngày thực tế từ API
                    datasets: [{
                        label: 'Doanh thu (Triệu VNĐ)',
                        data: stats.chartData, // Doanh thu thực tế từ API
                        borderColor: '#0ea5e9',
                        backgroundColor: gradient,
                        borderWidth: 3,
                        pointBackgroundColor: '#ffffff',
                        pointBorderColor: '#0ea5e9',
                        pointBorderWidth: 2,
                        pointRadius: 4,
                        pointHoverRadius: 6,
                        fill: true,
                        tension: 0.4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { borderDash: [5, 5], color: '#e2e8f0' }, border: { display: false } },
                        x: { grid: { display: false }, border: { display: false } }
                    }
                }
            });

            // Biểu đồ Doughnut (Tỷ lệ vé thực tế)
            const ctxTicket = document.getElementById('ticketTypeChart').getContext('2d');
            
            // Xử lý trường hợp chưa có ai mua vé (Trống)
            let chartLabels = stats.ticketLabels.length > 0 ? stats.ticketLabels : ['Chưa có dữ liệu'];
            let chartData = stats.ticketQuantities.length > 0 ? stats.ticketQuantities : [1];
            let bgColors = stats.ticketQuantities.length > 0 
                ? ['#0ea5e9', '#10b981', '#f59e0b', '#8b5cf6', '#ef4444'] 
                : ['#e2e8f0'];

            ticketChartInstance = new Chart(ctxTicket, {
                type: 'doughnut',
                data: {
                    labels: chartLabels,
                    datasets: [{
                        data: chartData,
                        backgroundColor: bgColors,
                        borderWidth: 0,
                        hoverOffset: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { position: 'bottom', labels: { padding: 20, usePointStyle: true, pointStyle: 'circle' } }
                    }
                }
            });
        }
    </script>
}
