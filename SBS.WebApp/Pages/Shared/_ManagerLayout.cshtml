@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Manager Dashboard</title>
    <!-- Google Fonts: Inter -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Toastr for Notifications -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <!-- Flatpickr for 24h Time format -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">

    <!-- Manager Custom CSS -->
    <link rel="stylesheet" href="~/css/manager.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <!-- Sidebar -->
    <nav id="sidebar" aria-label="Điều hướng Manager">
        <div class="sidebar-header">
            <a href="/Manager/Dashboard" class="brand">
                <i class="fa-solid fa-water"></i> SBS Manager
            </a>
            <button type="button" class="mobile-sidebar-close" id="sidebarClose"
                    aria-label="Đóng menu điều hướng">
                <i class="fa-solid fa-xmark" aria-hidden="true"></i>
            </button>
        </div>
        <div class="nav flex-column">
            @{ var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? ""; }
            <a class="nav-link @(currentPage.StartsWith("/Manager/Dashboard") ? "active" : "")" href="/Manager/Dashboard">
                <i class="fa-solid fa-chart-pie w-20px"></i> Tổng quan
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Pools") ? "active" : "")" href="/Manager/Pools">
                <i class="fa-solid fa-swimming-pool w-20px"></i> Bể bơi
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Slots") ? "active" : "")" href="/Manager/Slots">
                <i class="fa-regular fa-clock w-20px"></i> Khung giờ
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Tickets") ? "active" : "")" href="/Manager/Tickets">
                <i class="fa-solid fa-ticket w-20px"></i> Loại vé
            </a>
            <a class="nav-link @(currentPage.StartsWith("/Manager/Pricing") ? "active" : "")" href="/Manager/Pricing">
                <i class="fa-solid fa-tags w-20px me-2"></i> Bảng giá
            </a>
            <hr class="my-2" style="border-color: rgba(255,255,255,0.1);">
            <a class="nav-link text-white-50" href="/" style="font-size: 0.9rem;">
                <i class="fa-solid fa-arrow-left w-20px me-2"></i> Về trang chủ
            </a>
        </div>
    </nav>
    <button type="button" class="sidebar-backdrop" id="sidebarBackdrop"
            aria-label="Đóng menu điều hướng" tabindex="-1"></button>

    <!-- Main Content -->
    <div id="content">
        <!-- Topbar -->
        <div class="topbar">
            <div class="topbar-left">
                <button type="button" class="mobile-sidebar-toggle" id="sidebarToggle"
                        aria-label="Mở menu điều hướng" aria-controls="sidebar" aria-expanded="false">
                    <i class="fa-solid fa-bars" aria-hidden="true"></i>
                </button>
                <div class="breadcrumb mb-0 fw-medium text-muted" title="@ViewData["Breadcrumb"]">
                    @ViewData["Breadcrumb"]
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                @{
                    var mgrFullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Manager";
                    var mgrAvatarUrl = User.FindFirst("AvatarUrl")?.Value;
                    var defaultMgrAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(mgrFullName)}&background=0D8ABC&color=fff";
                    var mgrAvatarSrc = !string.IsNullOrEmpty(mgrAvatarUrl) ? mgrAvatarUrl : defaultMgrAvatar;
                    // Kiểm tra trực tiếp quyền truy cập Manager từ Server-side
                    if (User.Identity == null || !User.Identity.IsAuthenticated || !User.IsInRole("Manager"))
                    {
                        Context.Response.Redirect("/Auth/Login");
                    }
                }
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle rounded-pill border-0 shadow-sm manager-user-menu" type="button" data-bs-toggle="dropdown" id="userMenuBtn">
                        <img id="userAvatar" src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(mgrFullName)&background=0D8ABC&color=fff" class="rounded-circle manager-user-avatar" width="32" height="32" alt="" />
                        <span id="userNameDisplay" class="manager-user-name">@mgrFullName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item text-danger" href="/Auth/Logout">&#x0110;&#x0103;ng xu&#x1EA5;t</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- Page Content -->
        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <!-- Global Loader -->
    <div id="global-loader">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <!-- Flatpickr JS -->
    <script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>
    <script>
        (() => {
            const sidebar = document.getElementById('sidebar');
            const sidebarToggle = document.getElementById('sidebarToggle');
            const sidebarClose = document.getElementById('sidebarClose');
            const sidebarBackdrop = document.getElementById('sidebarBackdrop');
            const mobileQuery = window.matchMedia('(max-width: 991.98px)');

            function setSidebarOpen(isOpen, returnFocus = false) {
                const shouldOpen = mobileQuery.matches && isOpen;
                document.body.classList.toggle('manager-sidebar-open', shouldOpen);
                sidebarToggle.setAttribute('aria-expanded', shouldOpen ? 'true' : 'false');
                sidebar.setAttribute('aria-hidden', mobileQuery.matches && !shouldOpen ? 'true' : 'false');
                sidebar.inert = mobileQuery.matches && !shouldOpen;

                if (shouldOpen) {
                    sidebarClose.focus();
                } else if (returnFocus) {
                    sidebarToggle.focus();
                }
            }

            sidebarToggle.addEventListener('click', () => setSidebarOpen(true));
            sidebarClose.addEventListener('click', () => setSidebarOpen(false, true));
            sidebarBackdrop.addEventListener('click', () => setSidebarOpen(false, true));

            sidebar.querySelectorAll('a').forEach(link => {
                link.addEventListener('click', () => {
                    if (mobileQuery.matches) setSidebarOpen(false);
                });
            });

            document.addEventListener('keydown', event => {
                if (event.key === 'Escape' && document.body.classList.contains('manager-sidebar-open')) {
                    setSidebarOpen(false, true);
                }
            });

            if (typeof mobileQuery.addEventListener === 'function') {
                mobileQuery.addEventListener('change', () => setSidebarOpen(false));
            } else {
                mobileQuery.addListener(() => setSidebarOpen(false));
            }
            setSidebarOpen(false);
        })();
    </script>
    <script>
        // Lấy token được giải mã ở server và nhúng vào biến JS
        // Cookie gốc đã được trình duyệt ẩn đi và mã hóa qua .AspNetCore.Cookies (HttpOnly)
        window.ACCESS_TOKEN = '@(User.FindFirst("AccessToken")?.Value ?? "")';
        window.API_BASE_URL = '@Configuration["PublicApiBaseUrl"]' || window.location.origin;

        // --- HỖ TRỢ REFRESH TOKEN ---
        let isRefreshing = false;
        let refreshSubscribers = [];

        function subscribeTokenRefresh(cb) {
            refreshSubscribers.push(cb);
        }

        function onRefreshed(token) {
            refreshSubscribers.forEach(cb => cb(token));
            refreshSubscribers = [];
        }

        // --- 3. CẤU HÌNH GỌI API (MANAGER API INTERCEPTOR) ---
        toastr.options = { "closeButton": true, "progressBar": true, "positionClass": "toast-top-right", "timeOut": "3000" };

        const api = {
            baseURL: window.API_BASE_URL + '/api/manager',
            request: function(method, url, data) {
                return new Promise((resolve, reject) => {
                    $('#global-loader').css('display', 'flex');
                    
                    const token = window.ACCESS_TOKEN;
                    const headers = { 
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    };
                    
                    $.ajax({
                        url: this.baseURL + url, 
                        type: method, 
                        headers: headers,
                        xhrFields: {
                            withCredentials: true // Tự động gửi kèm Cookie của API
                        },
                        data: data ? JSON.stringify(data) : null,
                        success: function(response) { 
                            $('#global-loader').hide(); 
                            resolve(response); 
                        },
                        error: function(xhr) {
                            const status = xhr.status;
                            let dataObj = {};
                            try { dataObj = JSON.parse(xhr.responseText); } catch(e) {}
                            
                            if (status === 401) {
                                // BẮT ĐẦU REFRESH TOKEN LOGIC
                                const retryRequest = new Promise((resolveRetry, rejectRetry) => {
                                    subscribeTokenRefresh((newToken) => {
                                        if (newToken) {
                                            headers['Authorization'] = 'Bearer ' + newToken;
                                            $.ajax({
                                                url: api.baseURL + url,
                                                type: method,
                                                headers: headers,
                                                xhrFields: { withCredentials: true },
                                                data: data ? JSON.stringify(data) : null,
                                                success: resolveRetry,
                                                error: rejectRetry
                                            });
                                        } else {
                                            rejectRetry(xhr);
                                        }
                                    });

                                    if (!isRefreshing) {
                                        isRefreshing = true;
                                        $.ajax({
                                            url: window.API_BASE_URL + '/api/Auth/refresh',
                                            type: 'POST',
                                            xhrFields: { withCredentials: true },
                                            success: function(res) {
                                                isRefreshing = false;
                                                window.ACCESS_TOKEN = res.accessToken;
                                                onRefreshed(res.accessToken);
                                            },
                                            error: function() {
                                                isRefreshing = false;
                                                onRefreshed(null);
                                                $('#global-loader').hide();
                                                toastr.error('Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.');
                                                setTimeout(() => window.location.href = '/Auth/Logout', 1500);
                                            }
                                        });
                                    }
                                });

                                retryRequest.then(resolve).catch(reject);
                                return; // Kết thúc để chờ Promise retry xử lý
                            }

                            // XỬ LÝ CÁC LỖI KHÁC NẾU KHÔNG PHẢI 401 HOẶC REFRESH THẤT BẠI
                            $('#global-loader').hide();
                            console.error("API Error: ", xhr);

                            if (status === 403) {
                                toastr.error('Bạn không có quyền thực hiện thao tác này.');
                            } else if (status === 400 || status === 404 || status === 422) {
                                const errs = dataObj.errors || dataObj.Errors;
                                const msg = dataObj.message || dataObj.Message;
                                const title = dataObj.title || dataObj.Title;
                                
                                if (errs && Array.isArray(errs) && errs.length > 0) {
                                    errs.forEach(err => toastr.error(err));
                                } else if (errs && typeof errs === 'object') {
                                    Object.values(errs).forEach(errArr => {
                                        if (Array.isArray(errArr)) errArr.forEach(err => toastr.error(err));
                                        else toastr.error(errArr); 
                                    });
                                } else if (msg) {
                                    toastr.error(msg);
                                } else if (title) {
                                    toastr.error(title);
                                } else {
                                    toastr.error('Lỗi (' + status + '): ' + (xhr.responseText ? xhr.responseText.substring(0,100) : 'Yêu cầu không hợp lệ.'));
                                }
                            } else if (status === 500) {
                                toastr.error('Đã xảy ra lỗi hệ thống (500). Vui lòng thử lại sau.');
                            } else {
                                toastr.error('Lỗi máy chủ không xác định.');
                            }
                            reject(xhr);
                        }
                    });
                });
            },
            get: function(url) { return this.request('GET', url); },
            post: function(url, data) { return this.request('POST', url, data); },
            put: function(url, data) { return this.request('PUT', url, data); },
            patch: function(url, data) { return this.request('PATCH', url, data); },
            delete: function(url) { return this.request('DELETE', url); },
            uploadFile: function(url, file) {
                return new Promise((resolve, reject) => {
                    $('#global-loader').css('display', 'flex');
                    const formData = new FormData();
                    formData.append('file', file);

                    const doUpload = (token) => {
                        $.ajax({
                            url: this.baseURL + url,
                            type: 'POST',
                            data: formData,
                            processData: false,
                            contentType: false,
                            headers: {
                                'Authorization': 'Bearer ' + token
                            },
                            xhrFields: { withCredentials: true },
                            success: function(response) {
                                $('#global-loader').hide();
                                resolve(response);
                            },
                            error: function(xhr) {
                                if (xhr.status === 401) {
                                    const retryUpload = new Promise((resolveRetry, rejectRetry) => {
                                        subscribeTokenRefresh((newToken) => {
                                            if (newToken) {
                                                doUpload(newToken).then(resolveRetry).catch(rejectRetry);
                                            } else {
                                                rejectRetry(xhr);
                                            }
                                        });

                                        if (!isRefreshing) {
                                            isRefreshing = true;
                                            $.ajax({
                                                url: window.API_BASE_URL + '/api/auth/refresh',
                                                type: 'POST',
                                                xhrFields: { withCredentials: true },
                                                success: function(res) {
                                                    isRefreshing = false;
                                                    window.ACCESS_TOKEN = res.accessToken;
                                                    onRefreshed(res.accessToken);
                                                },
                                                error: function() {
                                                    isRefreshing = false;
                                                    onRefreshed(null);
                                                    $('#global-loader').hide();
                                                    toastr.error('Phiên đăng nhập đã hết hạn. Vui lòng đăng nhập lại.');
                                                    setTimeout(() => window.location.href = '/Auth/Logout', 1500);
                                                }
                                            });
                                        }
                                    });

                                    retryUpload.then(resolve).catch(reject);
                                    return;
                                }

                                $('#global-loader').hide();
                                console.error("Upload Error: ", xhr);
                                let errorMsg = 'Lỗi khi tải ảnh lên. Vui lòng thử lại.';
                                try {
                                    const dataObj = JSON.parse(xhr.responseText);
                                    if (dataObj.message) errorMsg = dataObj.message;
                                    else if (dataObj.Message) errorMsg = dataObj.Message;
                                    else if (typeof dataObj === 'string') errorMsg = dataObj;
                                } catch(e) {
                                    if (xhr.responseText) errorMsg = xhr.responseText.substring(0, 100);
                                }
                                toastr.error(errorMsg);
                                reject(xhr);
                            }
                        });
                    };

                    doUpload(window.ACCESS_TOKEN || '');
                });
            }
        };
    </script>
    
    @RenderSection("Scripts", required: false)
</body>
</html>
