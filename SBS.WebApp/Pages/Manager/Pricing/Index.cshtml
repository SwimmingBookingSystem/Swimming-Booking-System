@page
@model SBS.WebApp.Pages.Manager.Pricing.IndexModel
@{
    Layout = "_ManagerLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/manager-pricing.css" asp-append-version="true" />
}

<!-- Page Header -->
<div class="pricing-header">
    <h4><i class="fa-solid fa-tags me-2 text-primary"></i>Bảng giá theo Bể bơi</h4>
</div>

<!-- Pool Selector -->
<div class="row align-items-end mb-4">
    <div class="col-md-8 col-lg-6">
        <label class="form-label fw-bold text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 0.5px;">Cơ sở / Bể bơi đang chọn</label>
        <div class="dropdown">
            <button class="btn w-100 text-start d-flex align-items-center justify-content-between shadow-sm bg-white" type="button" data-bs-toggle="dropdown" aria-expanded="false" style="padding: 12px 16px; border-radius: 12px; border: 1px solid #cbd5e1; transition: all 0.2s;">
                <div class="d-flex align-items-center gap-3">
                    <img id="selectorAvatar" src="https://placehold.co/48x48?text=?" class="rounded-3 shadow-sm" style="width: 48px; height: 48px; object-fit: cover; border: 2px solid #fff;" alt="">
                    <div>
                        <h6 class="mb-1 fw-bold text-dark" id="selectorPoolName">Đang tải...</h6>
                        <div class="text-muted" id="selectorPoolInfo" style="font-size: 0.8rem;"><i class="fa-solid fa-spinner fa-spin me-1"></i> Vui lòng đợi</div>
                    </div>
                </div>
                <div class="bg-light rounded-circle d-flex align-items-center justify-content-center text-muted" style="width: 32px; height: 32px;">
                    <i class="fa-solid fa-chevron-down fs-6"></i>
                </div>
            </button>
            <ul class="dropdown-menu w-100 shadow-lg border-0 p-2 mt-2" id="poolDropdownMenu" style="max-height: 400px; overflow-y: auto; border-radius: 12px; animation: dropdownFade 0.2s ease-out;">
                <!-- js render -->
            </ul>
        </div>
    </div>
    <div class="col-md-4 col-lg-6 d-flex justify-content-md-end align-items-end gap-2 mt-3 mt-md-0">
        <div>
            <label class="form-label fw-bold text-muted text-uppercase mb-2" style="font-size: 0.8rem; letter-spacing: 0.5px;">Lọc loại vé</label>
            <select class="form-select shadow-sm" id="categoryFilter" onchange="applyFilter()" style="border-radius: 10px; border: 1px solid #cbd5e1; height: 44px; min-width: 150px;">
                <option value="All">Tất cả</option>
                <option value="Single">Chỉ Vé đơn</option>
                <option value="Combo">Chỉ Combo</option>
            </select>
        </div>
        <button class="btn btn-outline-primary shadow-sm fw-semibold" onclick="refreshPricing()" style="border-radius: 10px; height: 44px; padding: 0 20px;">
            <i class="fa-solid fa-rotate-right me-2"></i>Làm mới
        </button>
    </div>
</div>

<style>
    .dropdown-menu .dropdown-item {
        padding: 10px 16px;
        border-radius: 8px;
        transition: all 0.2s;
        margin-bottom: 2px;
    }
    .dropdown-menu .dropdown-item:hover, .dropdown-menu .dropdown-item:focus {
        background-color: #f0f9ff;
        color: #0284c7;
    }
    .dropdown-menu .dropdown-item.active {
        background-color: #0284c7;
        color: #fff;
    }
    .dropdown-menu .dropdown-item.active .text-muted {
        color: #e0f2fe !important;
    }
    @@keyframes dropdownFade {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }
</style>

<!-- Pricing Table -->
<div class="pricing-table-wrapper" id="pricingTableWrapper">
    <table class="pricing-table">
        <thead>
            <tr>
                <th>Loại vé</th>
                <th>Mã</th>
                <th>Loại</th>
                <th>Giá gốc (Base)</th>
                <th>Giá tại bể bơi</th>
                <th>Chênh lệch</th>
                <th>Trạng thái</th>
                <th style="width: 160px; text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody id="pricingTableBody">
            <tr>
                <td colspan="8">
                    <div class="pricing-empty">
                        <i class="fa-solid fa-hand-pointer"></i>
                        <p>Chọn một bể bơi ở trên để xem bảng giá.</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    <div class="pricing-summary" id="pricingSummary" style="display: none;">
        <span id="summaryText"></span>
    </div>
</div>

<!-- Edit Price Modal -->
<div class="modal fade" id="priceModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content price-edit-modal">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fa-solid fa-pen me-2"></i>Cập nhật giá vé</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editPoolId">
                <input type="hidden" id="editTicketTypeId">

                <div class="current-info">
                    <div class="row">
                        <div class="col-6">
                            <label>Loại vé</label>
                            <div class="value" id="priceModalTicketName">—</div>
                        </div>
                        <div class="col-6">
                            <label>Giá gốc (Base)</label>
                            <div class="value" id="priceModalBasePrice">—</div>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Giá mới tại bể bơi (VNĐ) <span class="text-danger">*</span></label>
                    <input type="number" class="form-control form-control-lg" id="newPrice" min="0" step="1000" placeholder="Nhập giá mới">
                    <div class="form-text">Để giá 0 hoặc bằng giá gốc nếu không muốn áp giá riêng.</div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-4" onclick="savePrice()">
                    <i class="fa-solid fa-save me-1"></i> Lưu giá
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fa-solid fa-triangle-exclamation text-warning mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3" id="confirmTitle">Xác nhận</h5>
                <p class="text-muted mb-4" id="confirmMessage"></p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light border w-50" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger w-50" id="btnConfirmAction">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let pools = [];
        let poolTickets = [];
        let selectedPoolId = null;
        let priceModal, confirmModal, confirmCb;

        $(document).ready(function () {
            priceModal = new bootstrap.Modal(document.getElementById('priceModal'));
            confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
            loadPools();
        });

        // ── LOAD POOLS ───────────────────────────────────────────────
        async function loadPools() {
            try {
                const res = await api.get('/pools?pageSize=100');
                pools = res.items || [];
                renderPoolTabs();
                if (pools.length > 0) {
                    selectPool(pools[0].poolId);
                }
            } catch (e) { }
        }

        function renderPoolTabs() {
            if (pools.length === 0) {
                $('#poolDropdownMenu').html('<li class="p-3 text-muted text-center small">Chưa có bể bơi nào. Vui lòng tạo bể bơi trước.</li>');
                $('#selectorPoolName').text('Chưa có dữ liệu');
                $('#selectorPoolInfo').html('Vui lòng tạo bể bơi mới');
                return;
            }
            let html = '';
            pools.forEach(p => {
                html += `
                <li>
                    <a class="dropdown-item d-flex align-items-center gap-3" href="#" onclick="selectPool(${p.poolId}); return false;" data-pool-id="${p.poolId}">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 36px; height: 36px;">
                            <i class="fa-solid fa-water"></i>
                        </div>
                        <div>
                            <div class="fw-bold text-dark">${p.poolName}</div>
                            <div class="text-muted small" style="font-size: 0.75rem;"><i class="fa-solid fa-location-dot me-1"></i>${p.address}</div>
                        </div>
                    </a>
                </li>`;
            });
            $('#poolDropdownMenu').html(html);
        }

        async function selectPool(poolId) {
            selectedPoolId = poolId;
            // Update active state in dropdown
            $('.dropdown-item').removeClass('active');
            $(`.dropdown-item[data-pool-id="${poolId}"]`).addClass('active');

            // Update selector button banner
            const pool = pools.find(p => p.poolId === poolId);
            if (pool) {
                const coverImg = pool.images && pool.images.length > 0
                    ? (pool.images.find(i => i.isCover)?.imageUrl || pool.images[0].imageUrl)
                    : 'https://placehold.co/56x56?text=' + encodeURIComponent(pool.poolName.charAt(0));
                $('#selectorAvatar').attr('src', coverImg);
                $('#selectorPoolName').text(pool.poolName);
                $('#selectorPoolInfo').html(`<i class="fa-solid fa-location-dot me-1"></i>${pool.address} &nbsp;|&nbsp; <i class="fa-regular fa-clock me-1"></i>${pool.openingTime} - ${pool.closingTime}`);
            }

            await loadPoolTickets(poolId);
        }

        // ── LOAD POOL TICKETS ────────────────────────────────────────
        async function loadPoolTickets(poolId) {
            try {
                poolTickets = await api.get(`/pools/${poolId}/ticket-types`);
                applyFilter();
            } catch (e) {
                renderPricingTable([]);
            }
        }

        function refreshPricing() {
            if (selectedPoolId) loadPoolTickets(selectedPoolId);
        }

        function applyFilter() {
            const filterVal = $('#categoryFilter').val();
            if (filterVal === 'All') {
                renderPricingTable(poolTickets);
            } else {
                const filtered = poolTickets.filter(t => t.category === filterVal);
                renderPricingTable(filtered);
            }
        }

        // ── RENDER TABLE ─────────────────────────────────────────────
        function renderPricingTable(list) {
            if (!list || list.length === 0) {
                $('#pricingTableBody').html(`
                    <tr><td colspan="8">
                        <div class="pricing-empty">
                            <i class="fa-solid fa-tags"></i>
                            <p>Bể bơi này chưa có loại vé nào được gán.<br>
                            <span class="small">Hãy vào trang <a href="/Manager/Tickets" class="text-primary fw-semibold">Quản lý Loại vé</a> để tạo vé và áp dụng cho bể bơi này.</span></p>
                        </div>
                    </td></tr>`);
                $('#pricingSummary').hide();
                return;
            }

            let html = '';
            list.forEach(t => {
                const isActive = t.status === 'Active';
                const isCombo = t.category === 'Combo';
                const isOverride = t.price !== null && t.price !== undefined;
                const trueSystemPrice = t.basePrice * (1 - (t.discountPercent || 0) / 100);
                const currentPrice = isOverride ? t.price : trueSystemPrice;
                const diff = currentPrice - trueSystemPrice;
                
                let diffHtml = '';
                if (diff > 0) {
                    diffHtml = `<span class="price-diff up"><i class="fa-solid fa-arrow-up"></i> +${formatMoney(diff)}</span>`;
                } else if (diff < 0) {
                    diffHtml = `<span class="price-diff down"><i class="fa-solid fa-arrow-down"></i> ${formatMoney(diff)}</span>`;
                } else {
                    diffHtml = `<span class="price-diff same">Bằng giá gốc</span>`;
                }
                
                let currentPriceHtml = isOverride 
                    ? `<span class="price-current">${formatMoney(currentPrice)}</span>` 
                    : `<span class="price-current text-muted"><i class="fa-solid fa-link me-1"></i>${formatMoney(currentPrice)}</span> <br><small class="text-muted">(Giá gốc)</small>`;

                html += `
                <tr>
                    <td>
                        <div class="ticket-info-cell">
                            <div class="ticket-icon ${isCombo ? 'combo' : 'single'}">
                                <i class="fa-solid ${isCombo ? 'fa-cubes' : 'fa-ticket'}"></i>
                            </div>
                            <div>
                                <div class="ticket-name">${t.ticketName}</div>
                                <div class="ticket-code">${t.ticketCode}</div>
                            </div>
                        </div>
                    </td>
                    <td><span style="font-family: monospace; color: #0284c7; font-weight: 600;">${t.ticketCode}</span></td>
                    <td>
                        <span class="category-badge ${isCombo ? 'combo' : 'single'}">
                            <i class="fa-solid ${isCombo ? 'fa-cubes' : 'fa-ticket'}"></i> ${t.category}
                        </span>
                    </td>
                    <td>
                        <span class="price-base" style="${t.discountPercent > 0 ? 'text-decoration: line-through; color: #999; font-size: 0.85rem;' : ''}">${formatMoney(t.basePrice)}</span>
                        ${t.discountPercent > 0 ? `<br><span class="price-base text-success fw-bold">${formatMoney(trueSystemPrice)}</span> <span class="badge bg-danger ms-1">-${t.discountPercent}%</span>` : ''}
                    </td>
                    <td>${currentPriceHtml}</td>
                    <td>${diffHtml}</td>
                    <td>
                        <span class="pricing-status ${isActive ? 'active' : (t.status === 'NotApplied' ? 'not-applied' : 'closed')}" 
                              style="${t.status === 'NotApplied' ? 'background: #f1f5f9; color: #64748b; border: 1px dashed #cbd5e1;' : ''}">
                            ${isActive ? 'Hoạt động' : (t.status === 'NotApplied' ? 'Chưa áp dụng' : 'Đã đóng')}
                        </span>
                    </td>
                    <td>
                        <div class="d-flex gap-1 justify-content-center">
                            <button class="pricing-action-btn" title="Sửa giá" onclick="openPriceModal(${t.ticketTypeId})" ${t.status === 'NotApplied' ? 'disabled style="opacity: 0.5;"' : ''}>
                                <i class="fa-solid fa-pen"></i>
                            </button>
                            ${isActive
                                ? `<button class="pricing-action-btn" title="Ngừng bán vé tại bể này" onclick="togglePoolTicket(${t.ticketTypeId}, 'close')" style="color:#ef4444;"><i class="fa-solid fa-ban"></i></button>`
                                : `<button class="pricing-action-btn" title="${t.status === 'NotApplied' ? 'Áp dụng bán' : 'Mở lại'}" onclick="togglePoolTicket(${t.ticketTypeId}, 'open')" style="${t.status === 'NotApplied' ? 'color:#10b981;' : ''}">
                                    <i class="fa-solid ${t.status === 'NotApplied' ? 'fa-check' : 'fa-rotate-left'}"></i>
                                   </button>`
                            }
                        </div>
                    </td>
                </tr>`;
            });
            $('#pricingTableBody').html(html);

            // Summary
            const activeCount = list.filter(t => t.status === 'Active').length;
            $('#summaryText').text(`Tổng: ${list.length} loại vé | ${activeCount} đang hoạt động`);
            $('#pricingSummary').show();
        }

        // ── EDIT PRICE ───────────────────────────────────────────────
        function openPriceModal(ticketTypeId) {
            const t = poolTickets.find(x => x.ticketTypeId === ticketTypeId);
            if (!t) return;
            $('#editPoolId').val(selectedPoolId);
            $('#editTicketTypeId').val(ticketTypeId);
            $('#priceModalTicketName').text(`${t.ticketCode} — ${t.ticketName}`);
            
            const trueSystemPrice = t.basePrice * (1 - (t.discountPercent || 0) / 100);
            $('#priceModalBasePrice').text(formatMoney(trueSystemPrice));
            
            const isOverride = t.price !== null && t.price !== undefined;
            $('#newPrice').val(isOverride ? t.price : '');
            priceModal.show();
        }

        async function savePrice() {
            const poolId = parseInt($('#editPoolId').val());
            const ticketTypeId = parseInt($('#editTicketTypeId').val());
            let priceVal = $('#newPrice').val().trim();
            
            let price = priceVal === '' ? null : parseFloat(priceVal);

            if (price !== null && (isNaN(price) || price < 0)) {
                toastr.warning('Vui lòng nhập giá hợp lệ.');
                return;
            }

            try {
                await api.patch(`/pools/${poolId}/ticket-types/${ticketTypeId}/price`, { price: price });
                toastr.success('Cập nhật giá thành công!');
                priceModal.hide();
                loadPoolTickets(poolId);
            } catch (e) { }
        }

        // ── TOGGLE STATUS ────────────────────────────────────────────
        function togglePoolTicket(ticketTypeId, action) {
            const t = poolTickets.find(x => x.ticketTypeId === ticketTypeId);
            const label = action === 'close' ? 'ngừng bán' : (t.status === 'NotApplied' ? 'áp dụng (bật bán)' : 'mở lại');
            $('#confirmTitle').text(`Xác nhận ${label} vé?`);
            $('#confirmMessage').text(`Bạn có chắc muốn ${label} vé "${t?.ticketName}" tại bể bơi này?`);
            confirmCb = async () => {
                try {
                    await api.patch(`/pools/${selectedPoolId}/ticket-types/${ticketTypeId}/${action}`);
                    toastr.success(`Đã ${label} vé thành công.`);
                    confirmModal.hide();
                    loadPoolTickets(selectedPoolId);
                } catch (e) { }
            };
            confirmModal.show();
        }

        $('#btnConfirmAction').click(function () { if (confirmCb) confirmCb(); });

        // ── UTILS ────────────────────────────────────────────────────
        function formatMoney(v) {
            return new Intl.NumberFormat('vi-VN').format(Math.round(v)) + ' ₫';
        }
    </script>
}
