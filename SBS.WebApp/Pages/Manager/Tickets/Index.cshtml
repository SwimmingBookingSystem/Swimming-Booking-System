@page
@model SBS.WebApp.Pages.Manager.Tickets.IndexModel
@{
    Layout = "_ManagerLayout";
}

@section Styles {
    <link rel="stylesheet" href="~/css/manager-tickets.css" asp-append-version="true" />
}

<!-- Page Header -->
<div class="tickets-header">
    <h4><i class="fa-solid fa-ticket me-2 text-primary"></i>Quản lý Loại vé</h4>
    <div class="d-flex gap-2">
        <button class="btn btn-outline-secondary" onclick="seedDefaults()">
            <i class="fa-solid fa-wand-magic-sparkles me-1"></i> Tạo vé mặc định
        </button>
        <a href="/Manager/Tickets/Create" class="btn btn-primary">
            <i class="fa-solid fa-plus me-1"></i> Tạo loại vé mới
        </a>
    </div>
</div>

<!-- Stats -->
<div class="ticket-stats" id="statsRow">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="fa-solid fa-layer-group"></i></div>
        <div><div class="stat-value" id="statTotal">0</div><div class="stat-label">Tổng loại vé</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="fa-solid fa-ticket"></i></div>
        <div><div class="stat-value" id="statSingle">0</div><div class="stat-label">Vé đơn (Single)</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon purple"><i class="fa-solid fa-cubes"></i></div>
        <div><div class="stat-value" id="statCombo">0</div><div class="stat-label">Vé combo</div></div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="fa-solid fa-circle-check"></i></div>
        <div><div class="stat-value" id="statActive">0</div><div class="stat-label">Đang hoạt động</div></div>
    </div>
</div>

<!-- Toolbar -->
<div class="tickets-toolbar">
    <div class="input-group">
        <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-search text-muted"></i></span>
        <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Tìm mã vé, tên vé...">
    </div>
    <select id="filterCategory" class="form-select">
        <option value="">Tất cả loại</option>
        <option value="Single">Vé đơn (Single)</option>
        <option value="Combo">Vé Combo</option>
    </select>
    <select id="filterStatus" class="form-select">
        <option value="">Tất cả trạng thái</option>
        <option value="Active">Đang hoạt động</option>
        <option value="Closed">Đã đóng</option>
    </select>
</div>

<!-- Table -->
<div class="ticket-table-wrapper">
    <table class="ticket-table">
        <thead>
            <tr>
                <th>Mã vé</th>
                <th>Tên vé</th>
                <th>Loại</th>
                <th>Giá gốc</th>
                <th>Giảm giá</th>
                <th>Giá thực</th>
                <th>Trạng thái</th>
                <th style="width: 120px; text-align: center;">Thao tác</th>
            </tr>
        </thead>
        <tbody id="ticketTableBody">
            <tr>
                <td colspan="8">
                    <div class="empty-state">
                        <i class="fa-solid fa-spinner fa-spin"></i>
                        <p>Đang tải dữ liệu...</p>
                    </div>
                </td>
            </tr>
        </tbody>
    </table>
    <div class="pagination-bar" id="paginationBar" style="display: none;">
        <div class="pagination-info" id="paginationInfo"></div>
        <div class="btn-group">
            <button class="btn btn-outline-secondary" id="btnPrev" onclick="changePage(-1)"><i class="fa-solid fa-chevron-left"></i></button>
            <button class="btn btn-outline-secondary" id="btnNext" onclick="changePage(1)"><i class="fa-solid fa-chevron-right"></i></button>
        </div>
    </div>
</div>

<!-- Confirm Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fa-solid fa-triangle-exclamation text-warning mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3" id="confirmTitle">Xác nhận</h5>
                <p class="text-muted mb-4" id="confirmMessage"></p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light border w-50" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger w-50" id="btnConfirmAction">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- History Modal -->
<div class="modal fade" id="historyModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-light border-0 py-3">
                <h5 class="modal-title fw-bold">
                    <i class="fa-solid fa-clock-rotate-left text-info me-2"></i> Lịch sử biến động giá: <span id="historyTicketName" class="text-primary"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 text-center">
                        <thead class="table-light">
                            <tr>
                                <th>Thời gian thay đổi</th>
                                <th>Giá gốc cũ</th>
                                <th>Giá gốc mới</th>
                                <th>Ưu đãi cũ</th>
                                <th>Ưu đãi mới</th>
                                <th>Thực hiện bởi</th>
                            </tr>
                        </thead>
                        <tbody id="historyTableBody">
                            <!-- JS render -->
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let allTickets = [];
        let currentPage = 1;
        const pageSize = 10;
        let totalCount = 0;
        let confirmModal, confirmCb;

        $(document).ready(function () {
            confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));

            loadTickets();
            loadTickets();

            // Filters
            $('#searchInput').on('input', debounce(() => { currentPage = 1; loadTickets(); }, 400));
            $('#filterCategory, #filterStatus').on('change', () => { currentPage = 1; loadTickets(); });
        });

        function debounce(fn, ms) {
            let t;
            return function (...args) { clearTimeout(t); t = setTimeout(() => fn.apply(this, args), ms); };
        }

        // ── DATA LOADING ──────────────────────────────────────────────
        async function loadTickets() {
            try {
                const cat = $('#filterCategory').val();
                const status = $('#filterStatus').val();
                let url = `/ticket-types?page=${currentPage}&pageSize=${pageSize}`;
                if (cat) url += `&category=${cat}`;
                if (status) url += `&status=${status}`;

                const res = await api.get(url);
                allTickets = res.items || [];
                totalCount = res.totalCount || 0;
                renderTable(allTickets);
                updateStats();
                updatePagination();
            } catch (e) { }
        }

        // ── STATS ────────────────────────────────────────────────────
        async function updateStats() {
            try {
                const all = await api.get('/ticket-types?pageSize=1000');
                const items = all.items || [];
                $('#statTotal').text(items.length);
                $('#statSingle').text(items.filter(t => t.category === 'Single').length);
                $('#statCombo').text(items.filter(t => t.category === 'Combo').length);
                $('#statActive').text(items.filter(t => t.status === 'Active').length);
            } catch (e) { }
        }

        // ── TABLE RENDERING ──────────────────────────────────────────
        function renderTable(list) {
            if (list.length === 0) {
                $('#ticketTableBody').html(`
                    <tr><td colspan="8">
                        <div class="empty-state">
                            <i class="fa-solid fa-ticket-simple"></i>
                            <p>Chưa có loại vé nào.</p>
                        </div>
                    </td></tr>`);
                return;
            }

            let html = '';
            list.forEach(t => {
                const actualPrice = t.basePrice * (1 - t.discountPercent / 100);
                const isCombo = t.category === 'Combo';
                const isActive = t.status === 'Active';

                html += `
                <tr>
                    <td><span class="ticket-code"><i class="fa-solid fa-barcode"></i> ${t.ticketCode}</span></td>
                    <td>
                        <div class="fw-semibold">${t.ticketName}</div>
                        ${isCombo && t.comboDetails ? `<div class="combo-items">${t.comboDetails.map(d => `<span class="combo-chip"><span class="qty">${d.quantity}×</span> ${d.singleTicketCode}</span>`).join('')}</div>` : ''}
                    </td>
                    <td>
                        <span class="category-badge ${isCombo ? 'combo' : 'single'}">
                            <i class="fa-solid ${isCombo ? 'fa-cubes' : 'fa-ticket'}"></i> ${t.category}
                        </span>
                    </td>
                    <td class="price-display">${formatMoney(t.basePrice)}</td>
                    <td>${t.discountPercent > 0 ? `<span class="discount-badge"><i class="fa-solid fa-arrow-down"></i> ${t.discountPercent}%</span>` : '<span class="text-muted">—</span>'}</td>
                    <td class="price-display">${formatMoney(actualPrice)}</td>
                    <td><span class="status-indicator ${isActive ? 'active' : 'closed'}">${isActive ? 'Hoạt động' : 'Đã đóng'}</span></td>
                    <td>
                        <div class="d-flex gap-1 justify-content-center">
                            <a class="action-btn" title="Chỉnh sửa" href="/Manager/Tickets/Edit?id=${t.ticketTypeId}"><i class="fa-solid fa-pen"></i></a>
                            <button class="action-btn text-info" title="Lịch sử giá" onclick="viewHistory(${t.ticketTypeId}, '${t.ticketName.replace(/'/g, "\\'")}')"><i class="fa-solid fa-clock-rotate-left"></i></button>
                            ${isActive
                        ? `<button class="action-btn danger" title="Đóng" onclick="toggleStatus(${t.ticketTypeId}, 'close')"><i class="fa-solid fa-ban"></i></button>`
                        : `<button class="action-btn" title="Mở lại" onclick="toggleStatus(${t.ticketTypeId}, 'open')"><i class="fa-solid fa-rotate-left"></i></button>`
                    }
                        </div>
                    </td>
                </tr>`;
            });
            $('#ticketTableBody').html(html);
        }

        // ── PAGINATION ───────────────────────────────────────────────
        function updatePagination() {
            const totalPages = Math.ceil(totalCount / pageSize);
            if (totalPages <= 1) { $('#paginationBar').hide(); return; }
            $('#paginationBar').show();
            $('#paginationInfo').text(`Trang ${currentPage} / ${totalPages} (${totalCount} loại vé)`);
            $('#btnPrev').prop('disabled', currentPage <= 1);
            $('#btnNext').prop('disabled', currentPage >= totalPages);
        }

        function changePage(delta) {
            currentPage += delta;
            loadTickets();
        }

        // ── STATUS TOGGLE ────────────────────────────────────────────
        function toggleStatus(id, action) {
            const ticket = allTickets.find(t => t.ticketTypeId === id);
            const label = action === 'close' ? 'đóng' : 'mở lại';
            $('#confirmTitle').text(`Xác nhận ${label} vé?`);
            $('#confirmMessage').text(`Bạn có chắc muốn ${label} loại vé "${ticket?.ticketName || id}"?`);
            confirmCb = async () => {
                try {
                    await api.patch(`/ticket-types/${id}/${action}`);
                    toastr.success(`Đã ${label} loại vé thành công.`);
                    confirmModal.hide();
                    loadTickets();
                } catch (e) { }
            };
            confirmModal.show();
        }

        $('#btnConfirmAction').click(function () { if (confirmCb) confirmCb(); });

        // ── HISTORY MODAL ────────────────────────────────────────────
        let historyModal;
        $(document).ready(function () {
            historyModal = new bootstrap.Modal(document.getElementById('historyModal'));
        });

        async function viewHistory(id, name) {
            $('#historyTicketName').text(name);
            $('#historyTableBody').html('<tr><td colspan="6"><i class="fa-solid fa-spinner fa-spin my-3"></i> Đang tải lịch sử...</td></tr>');
            historyModal.show();

            try {
                const history = await api.get(`/ticket-types/${id}/history`);
                
                if (!history || history.length === 0) {
                    $('#historyTableBody').html('<tr><td colspan="6" class="text-muted py-4"><i class="fa-solid fa-clock text-light fa-3x mb-2 d-block"></i>Chưa có lịch sử thay đổi giá nào cho vé này.</td></tr>');
                    return;
                }

                let html = '';
                history.forEach(h => {
                    const date = new Date(h.modifiedAt).toLocaleString('vi-VN');
                    html += `
                        <tr>
                            <td><span class="badge bg-light text-dark border"><i class="fa-regular fa-calendar me-1"></i> ${date}</span></td>
                            <td><span class="text-danger text-decoration-line-through">${formatMoney(h.oldBasePrice)}</span></td>
                            <td><span class="text-success fw-bold">${formatMoney(h.newBasePrice)}</span></td>
                            <td>${h.oldDiscountPercent}%</td>
                            <td><span class="fw-bold">${h.newDiscountPercent}%</span></td>
                            <td><span class="badge bg-secondary"><i class="fa-solid fa-user-shield me-1"></i> ${h.modifiedByUserName || 'System'}</span></td>
                        </tr>
                    `;
                });
                $('#historyTableBody').html(html);
            } catch (e) {
                $('#historyTableBody').html('<tr><td colspan="6" class="text-danger py-4"><i class="fa-solid fa-circle-xmark me-2"></i>Không thể tải dữ liệu lịch sử.</td></tr>');
            }
        }

        // ── SEED DEFAULTS ────────────────────────────────────────────
        async function seedDefaults() {
            try {
                const res = await api.post('/ticket-types/defaults', {});
                toastr.success(res.message || 'Thao tác thành công!');
                loadTickets();
            } catch (e) { }
        }

        // ── UTILS ────────────────────────────────────────────────────
        function formatMoney(v) {
            return new Intl.NumberFormat('vi-VN').format(Math.round(v)) + ' ₫';
        }
    </script>
}
