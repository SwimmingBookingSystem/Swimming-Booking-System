@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>
    <nav id="sidebar">
        <a href="/Admin/Dashboard" class="brand">
            <i class="fa-solid fa-shield-halved"></i> SBS Admin
        </a>
        <div class="nav flex-column">
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Dashboard/Index" ? "active" : "")" href="/Admin/Dashboard">
                <i class="fa-solid fa-chart-pie w-20px"></i> Tổng quan
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Users/Index" ? "active" : "")" href="/Admin/Users">
                <i class="fa-solid fa-users w-20px"></i> Khách hàng
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Employees/Index" ? "active" : "")" href="/Admin/Employees">
                <i class="fa-solid fa-user-tie w-20px"></i> Nhân sự
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Contacts/Index" ? "active" : "")" href="/Admin/Contacts">
                <i class="fa-solid fa-headset w-20px"></i> Liên hệ
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["page"]?.ToString() == "/Admin/Bookings/Index" ? "active" : "")" href="/Admin/Bookings">
                <i class="fa-solid fa-calendar-check w-20px"></i> Đặt chỗ
            </a>
            <hr class="my-2" style="border-color: rgba(255,255,255,0.1);">
            <a class="nav-link text-white-50" href="/" style="font-size: 0.85rem;">
                <i class="fa-solid fa-arrow-left w-20px"></i> Về trang chủ
            </a>
        </div>
    </nav>

    <div id="sidebar-overlay"></div>

    <div id="content">
        <div class="topbar">
            <div class="d-flex align-items-center gap-2">
                <button class="sidebar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
                    <i class="fa-solid fa-bars"></i>
                </button>
                <div class="breadcrumb mb-0 fw-medium text-muted">
                    @ViewData["Breadcrumb"]
                </div>
            </div>
            <div class="d-flex align-items-center gap-3">
                @{
                    var adminFullName = User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? "Admin";
                    var adminAvatarUrl = User.FindFirst("AvatarUrl")?.Value;
                    var defaultAdminAvatar = $"https://ui-avatars.com/api/?name={Uri.EscapeDataString(adminFullName)}&background=DC2626&color=fff";
                    var adminAvatarSrc = !string.IsNullOrEmpty(adminAvatarUrl) ? adminAvatarUrl : defaultAdminAvatar;
                    // Kiểm tra trực tiếp quyền truy cập Admin từ Server-side
                    if (User.Identity == null || !User.Identity.IsAuthenticated || !User.IsInRole("Admin"))
                    {
                        Context.Response.Redirect("/Auth/Login");
                    }
                }
                <div class="dropdown">
                    <button class="btn btn-light dropdown-toggle rounded-pill border-0 shadow-sm" type="button" data-bs-toggle="dropdown" id="userMenuBtn">
                        <img id="userAvatar" src="@adminAvatarSrc" class="rounded-circle me-2" width="32" height="32" style="object-fit: cover;" />
                        <span id="userNameDisplay">@adminFullName</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end">
                        <li><a class="dropdown-item text-danger" href="/Auth/Logout">&#x0110;&#x0103;ng xu&#x1EA5;t</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="page-content">
            @RenderBody()
        </div>
    </div>

    <div id="global-loader">
        <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;"></div>
    </div>

    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <script>
        // Lấy token được giải mã ở server và nhúng vào biến JS
        // Cookie gốc đã được trình duyệt ẩn đi và mã hóa qua .AspNetCore.Cookies (HttpOnly)
        window.ACCESS_TOKEN = '@(User.FindFirst("AccessToken")?.Value ?? "")';
        window.REFRESH_TOKEN = '@(User.FindFirst("RefreshToken")?.Value ?? "")';
        window.API_BASE_URL = '@Configuration["PublicApiBaseUrl"]' || window.location.origin;

        // TỰ ĐỘNG cấu hình gửi kèm JWT Token và tự động Refresh Token cho Admin khi AccessToken (15 phút) hết hạn
        $.ajaxSetup({
            beforeSend: function(xhr) {
                if (window.ACCESS_TOKEN) {
                    xhr.setRequestHeader('Authorization', 'Bearer ' + window.ACCESS_TOKEN);
                }
            },
            statusCode: {
                401: function() {
                    if (window.REFRESH_TOKEN && !window.IS_REFRESHING) {
                        window.IS_REFRESHING = true;
                        $.ajax({
                            url: window.API_BASE_URL + '/api/Auth/refresh',
                            type: 'POST',
                            contentType: 'application/json',
                            data: JSON.stringify({
                                accessToken: window.ACCESS_TOKEN,
                                refreshToken: window.REFRESH_TOKEN
                            }),
                            success: function(res) {
                                window.IS_REFRESHING = false;
                                if (res && res.accessToken) {
                                    window.ACCESS_TOKEN = res.accessToken;
                                    window.REFRESH_TOKEN = res.refreshToken || window.REFRESH_TOKEN;
                                    location.reload();
                                } else {
                                    window.location.href = '/Auth/Login';
                                }
                            },
                            error: function() {
                                window.IS_REFRESHING = false;
                                window.location.href = '/Auth/Login';
                            }
                        });
                    }
                }
            }
        });
    </script>
    <script src="~/js/admin/admin-api.js" asp-append-version="true"></script>

    <script>
        $(document).ready(function () {
            var $sidebar = $('#sidebar');
            var $overlay = $('#sidebar-overlay');

            $('#sidebarToggle').on('click', function () {
                $sidebar.toggleClass('open');
                $overlay.toggleClass('open');
            });

            $overlay.on('click', function () {
                $sidebar.removeClass('open');
                $overlay.removeClass('open');
            });

            $(window).on('resize', function () {
                if ($(window).width() > 767) {
                    $sidebar.removeClass('open');
                    $overlay.removeClass('open');
                }
            });
        });
    </script>

    @RenderSection("Scripts", required: false)
</body>
</html>
