@page
@model SBS.WebApp.Pages.Manager.Pools.IndexModel
@{
    Layout = "_ManagerLayout";
    ViewData["Title"] = "Quản lý Bể bơi";
    ViewData["Breadcrumb"] = "Quản lý / Bể bơi";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div class="d-flex gap-3 align-items-center">
        <div class="input-group shadow-sm" style="width: 300px;">
            <span class="input-group-text bg-white border-end-0"><i class="fa-solid fa-search text-muted"></i></span>
            <input type="text" id="searchInput" class="form-control border-start-0 ps-0" placeholder="Tìm tên bể bơi, địa chỉ...">
        </div>
        <select id="statusFilter" class="form-select shadow-sm" style="width: 180px;">
            <option value="">Tất cả trạng thái</option>
            <option value="Active">Hoạt động (Active)</option>
            <option value="Closed">Tạm đóng (Closed)</option>
        </select>
    </div>
    <a href="/Manager/Pools/Create" class="btn btn-primary shadow-sm">
        <i class="fa-solid fa-plus me-1"></i> Tạo bể bơi mới
    </a>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th class="ps-4 text-muted small fw-bold text-uppercase">Bể bơi</th>
                    <th class="text-muted small fw-bold text-uppercase">Địa chỉ</th>
                    <th class="text-muted small fw-bold text-uppercase text-center">Giờ hoạt động</th>
                    <th class="text-muted small fw-bold text-uppercase text-center">Trạng thái</th>
                    <th class="pe-4 text-muted small fw-bold text-uppercase text-end">Hành động</th>
                </tr>
            </thead>
            <tbody id="poolTableBody">
                <tr><td colspan="5" class="text-center p-4">Đang tải dữ liệu...</td></tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Confirm Close Modal -->
<div class="modal fade" id="confirmModal" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-body text-center p-4">
                <i class="fa-solid fa-triangle-exclamation text-warning mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3" id="confirmTitle">Xác nhận đóng</h5>
                <p class="text-muted mb-4" id="confirmMessage">Bạn có chắc chắn muốn thực hiện?</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light border w-50" data-bs-dismiss="modal">Hủy</button>
                    <button type="button" class="btn btn-danger w-50" id="btnConfirmAction">Xác nhận</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let pools = [];
        let confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
        let confirmActionCb = null;

        $(document).ready(function() {
            loadPools();

            $('#searchInput').on('input', function() { filterPools(); });
            $('#statusFilter').on('change', function() { filterPools(); });
        });

        async function loadPools() {
            try {
                const res = await api.get('/pools?pageSize=100');
                pools = res.items || [];
                filterPools();
            } catch (error) {}
        }

        function filterPools() {
            const search = $('#searchInput').val().toLowerCase();
            const status = $('#statusFilter').val();

            const filtered = pools.filter(p => {
                const matchSearch = p.poolName.toLowerCase().includes(search) || p.address.toLowerCase().includes(search);
                const matchStatus = status === '' || p.status === status;
                return matchSearch && matchStatus;
            });

            renderTable(filtered);
        }

        function renderTable(list) {
            let html = '';
            if (list.length === 0) {
                html = '<tr><td colspan="5" class="text-center text-muted p-5"><i class="fa-solid fa-inbox fa-3x mb-3"></i><br>Không tìm thấy bể bơi nào.</td></tr>';
            } else {
                list.forEach(p => {
                    const isClosed = p.status !== 'Active';
                    const badgeClass = isClosed ? 'bg-danger text-danger' : 'bg-success text-success';
                    const badgeText = isClosed ? 'CLOSED' : 'ACTIVE';
                    
                    const coverImg = p.images && p.images.length > 0 ? p.images.find(i => i.isCover)?.imageUrl || p.images[0].imageUrl : 'https://placehold.co/100x100?text=No+Image';

                    const toggleBtn = isClosed 
                        ? `<button class="btn btn-sm btn-light text-success border me-1" onclick="reopenPool(${p.poolId})" title="Mở lại"><i class="fa-solid fa-lock-open"></i></button>`
                        : `<button class="btn btn-sm btn-light text-warning border me-1" onclick="confirmClose(${p.poolId}, '${p.poolName}')" title="Đóng tạm thời"><i class="fa-solid fa-lock"></i></button>`;

                    html += `
                        <tr>
                            <td class="ps-4">
                                <div class="d-flex align-items-center gap-3">
                                    <img src="${coverImg}" alt="${p.poolName}" class="rounded-3 object-fit-cover shadow-sm" width="60" height="60">
                                    <div class="fw-bold text-dark">${p.poolName}</div>
                                </div>
                            </td>
                            <td>
                                <div class="text-muted small" style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    <i class="fa-solid fa-location-dot me-1 text-primary"></i> ${p.address}
                                </div>
                            </td>
                            <td class="text-center fw-medium">
                                ${p.openingTime.substring(0,5)} - ${p.closingTime.substring(0,5)}
                            </td>
                            <td class="text-center">
                                <span class="badge ${badgeClass} bg-opacity-10 rounded-pill px-3 py-2 fw-bold">${badgeText}</span>
                            </td>
                            <td class="text-end pe-4">
                                ${toggleBtn}
                                <a href="/Manager/Pools/Edit/${p.poolId}" class="btn btn-sm btn-light text-primary border" title="Chỉnh sửa">
                                    <i class="fa-solid fa-pen"></i>
                                </a>
                            </td>
                        </tr>
                    `;
                });
            }
            $('#poolTableBody').html(html);
        }

        function confirmClose(id, name) {
            $('#confirmTitle').text('Đóng Bể Bơi?');
            $('#confirmMessage').text(`Bể bơi "${name}" sẽ không nhận Booking mới nữa.`);
            confirmActionCb = async () => {
                try {
                    await api.patch(`/pools/${id}/close`);
                    toastr.success('Đã đóng bể bơi.');
                    confirmModal.hide();
                    loadPools();
                } catch(e) {}
            };
            confirmModal.show();
        }

        async function reopenPool(id) {
            try {
                await api.patch(`/pools/${id}/reopen`);
                toastr.success('Đã mở lại bể bơi.');
                loadPools();
            } catch(e) {}
        }

        $('#btnConfirmAction').click(function() {
            if (confirmActionCb) confirmActionCb();
        });
    </script>
}
