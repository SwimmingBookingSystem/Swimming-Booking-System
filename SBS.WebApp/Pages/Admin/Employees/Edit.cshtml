@page "/Admin/Employees/Edit/{userId:guid}"
@model SBS.WebApp.Pages.Admin.Employees.EditModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chỉnh sửa Nhân viên";
    ViewData["Breadcrumb"] = "Quản trị / Nhân sự / Chỉnh sửa";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4">
            <div class="card-header bg-transparent border-0 pt-4 pb-0 px-4">
                <h5 class="fw-bold mb-0">
                    <i class="fa-solid fa-user-pen text-primary me-2"></i>Chỉnh sửa thông tin nhân viên
                </h5>
                <p class="text-muted small mt-1 mb-0">Cập nhật thông tin tài khoản và phân công bể bơi.</p>
            </div>
            <div class="card-body p-4">
                <form id="editStaffForm">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Tên đăng nhập <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="userName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Email <span class="text-danger">*</span></label>
                            <input type="email" class="form-control" id="email" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Họ và tên <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="fullName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-medium small text-muted">Số điện thoại</label>
                            <input type="text" class="form-control" id="phoneNumber" placeholder="0xxxxxxxxx" pattern="^0\d{9,10}$" title="Số điện thoại phải bắt đầu bằng 0 và có 10-11 số">
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium small text-muted">Giới tính</label>
                            <select class="form-select" id="gender">
                                <option value="">---</option>
                                <option value="Nam">Nam</option>
                                <option value="Nữ">Nữ</option>
                                <option value="Khác">Khác</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-medium small text-muted">Ngày sinh</label>
                            <input type="date" class="form-control" id="dob" max="@DateTime.Now.ToString("yyyy-MM-dd")">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium small text-muted">Địa chỉ</label>
                            <input type="text" class="form-control" id="address">
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium small text-muted">Mật khẩu</label>
                            <div class="input-group">
                                <input type="password" class="form-control" id="password" placeholder="Để trống nếu không đổi">
                                <button class="btn btn-outline-secondary" type="button" id="togglePassword">
                                    <i class="fa-regular fa-eye"></i>
                                </button>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-medium small text-muted">Phân công bể bơi</label>
                            <select class="form-select" id="poolId">
                                <option value="">--- Không phân công ---</option>
                            </select>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4 pt-3 border-top">
                        <button type="submit" class="btn btn-primary fw-semibold px-4" id="btnSubmit">
                            <i class="fa-solid fa-save me-2"></i>Lưu thay đổi
                        </button>
                        <a href="/Admin/Employees" class="btn btn-light border fw-semibold px-4">Hủy</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const userId = '@Model.UserId';

        $(document).ready(function() {
            // Load user data
            Promise.all([
                api.get('/users'),
                api.get('/users/pools')
            ]).then(([users, pools]) => {
                const user = users.find(u => u.userId === userId);
                if (!user) {
                    toastr.error('Không tìm thấy người dùng.');
                    window.location.href = '/Admin/Employees';
                    return;
                }

                $('#userName').val(user.userName);
                $('#email').val(user.email);
                $('#fullName').val(user.fullName);
                $('#phoneNumber').val(user.phoneNumber || '');
                $('#gender').val(user.gender || '');
                $('#dob').val(user.dob || '');
                $('#address').val(user.address || '');

                const $poolSelect = $('#poolId');
                pools.forEach(p => {
                    $poolSelect.append(`<option value="${p.poolId}">${p.poolName} (${p.address})</option>`);
                });

                if (user.poolId) {
                    $poolSelect.val(user.poolId);
                }

                if (user.role === 'Manager') {
                    $poolSelect.closest('.col-12').hide();
                }
            }).catch(() => {
                toastr.error('Không thể tải dữ liệu.');
            });

            $('#editStaffForm').on('submit', async function(e) {
                e.preventDefault();
                const $btn = $('#btnSubmit');
                $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span>Đang xử lý...');

                const data = {
                    userId: userId,
                    userName: $('#userName').val().trim(),
                    email: $('#email').val().trim(),
                    fullName: $('#fullName').val().trim(),
                    phoneNumber: $('#phoneNumber').val().trim() || null,
                    gender: $('#gender').val() || null,
                    dob: $('#dob').val() || null,
                    address: $('#address').val().trim() || null,
                    poolId: $('#poolId').val() ? parseInt($('#poolId').val()) : null,
                    password: $('#password').val() || null
                };

                try {
                    await api.put(`/users/${userId}`, data);
                    toastr.success('Cập nhật thông tin thành công.');
                    setTimeout(() => window.location.href = '/Admin/Employees', 1000);
                } catch (e) {
                    $btn.prop('disabled', false).html('<i class="fa-solid fa-save me-2"></i>Lưu thay đổi');
                }
            });
        });

        $('#togglePassword').click(function() {
            const input = $('#password');
            const icon = $(this).find('i');
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
                icon.removeClass('fa-eye').addClass('fa-eye-slash');
            } else {
                input.attr('type', 'password');
                icon.removeClass('fa-eye-slash').addClass('fa-eye');
            }
        });
    </script>
}
