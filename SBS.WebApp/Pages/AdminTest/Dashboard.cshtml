@page
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Dashboard (Test) - Swimming Booking System</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        body {
            background-color: #f8fafc;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .dashboard-container {
            max-width: 800px;
            margin: 80px auto;
            padding: 20px;
        }
        .card {
            border-radius: 15px;
            border: none;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.05);
            padding: 30px;
        }
        .user-avatar {
            font-size: 4rem;
            color: #0284c7;
            margin-bottom: 15px;
        }
    </style>
</head>
<body>

    <div class="dashboard-container">
        <div class="card text-center">
            <div>
                <i class="bi bi-shield-lock-fill user-avatar"></i>
            </div>
            <h1 class="mb-3 text-danger">Khu vực Quản trị - BẢN KIỂM THỬ (Admin Dashboard Test)</h1>
            <p class="lead text-muted">Trang kiểm thử điều hướng đăng nhập thành công cho vai trò Admin.</p>
            
            <hr class="my-4">
            
            <div class="bg-light p-4 rounded-3 mb-4 text-start">
                <h5 class="mb-3 text-secondary">Thông tin phiên đăng nhập:</h5>
                <p><strong>Họ và tên:</strong> <span id="user-fullname" class="text-primary">Đang tải...</span></p>
                <p><strong>Tên tài khoản:</strong> <span id="user-username">Đang tải...</span></p>
                <p><strong>Vai trò:</strong> <span class="badge bg-danger fs-6" id="user-role">Admin</span></p>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a href="/" class="btn btn-outline-secondary px-4 py-2"><i class="bi bi-house-door"></i> Về Trang chủ</a>
                <button type="button" class="btn btn-danger px-4 py-2" id="logout-btn"><i class="bi bi-box-arrow-right"></i> Đăng xuất</button>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script>
        $(document).ready(function() {
            // Kiểm tra phân quyền ở Client-side
            const token = localStorage.getItem('accessToken');
            const role = localStorage.getItem('role');
            const fullName = localStorage.getItem('fullName');
            const userName = localStorage.getItem('userName');

            if (!token || !role || role.toLowerCase() !== 'admin') {
                // Nếu chưa đăng nhập hoặc sai vai trò -> Đẩy ngược về trang Login
                window.location.href = '/Auth/Login';
                return;
            }

            // Hiển thị thông tin người dùng
            $('#user-fullname').text(fullName);
            $('#user-username').text(userName);
            $('#user-role').text(role);

            // Logic Đăng xuất
            $('#logout-btn').click(function() {
                localStorage.clear();
                window.location.href = '/Auth/Login';
            });
        });
    </script>
</body>
</html>
